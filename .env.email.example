# Email Configuration for Borrowing Notifications
# Update these values based on your SMTP provider

# Generic SMTP Configuration (Recommended for production)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false

# Gmail Configuration Example
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-char-app-password

# Alternative providers:
# - SendGrid: EMAIL_HOST=smtp.sendgrid.net, EMAIL_PORT=587, EMAIL_USER=apikey
# - AWS SES: EMAIL_HOST=email-smtp.{region}.amazonaws.com, EMAIL_PORT=587
# - Azure: EMAIL_HOST=smtp.office365.com, EMAIL_PORT=587
# - Custom: Set EMAIL_HOST to your server, EMAIL_PORT to your port

# From address for emails
EMAIL_FROM=noreply@spistlibrary.edu.ph

# Override student email (optional - for testing)
# EMAIL_TO_OVERRIDE=admin@example.com

# Server & App Config
FRONTEND_URL=http://localhost:3000
PORT=3000
NODE_ENV=development
