# ============================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================
#  IMPORTANT SECURITY NOTES:
# 1. Copy this file to .env for production deployment
# 2. Replace ALL placeholder values with actual production values
# 3. NEVER commit .env file to version control
# 4. Keep secrets absolutely confidential
# 5. Use strong passwords and secrets (64+ characters)
# ============================================

# Database Configuration (Production)
DB_HOST=your-production-db-host.com
DB_USER=spist_library_user
DB_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD
DB_NAME=spist_library
DB_PORT=3306

# Server Configuration (Production)
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://library.spist.edu

# CORS Configuration (Production)
# Add all allowed domains (comma-separated, no spaces)
ALLOWED_ORIGINS=https://library.spist.edu,https://www.library.spist.edu

# Google OAuth 2.0 Configuration (Production)
#  IMPORTANT: Update these for your production domain
# Get credentials from: https://console.cloud.google.com/
# Set Authorized JavaScript origins: https://library.spist.edu
# Set Authorized redirect URIs: https://library.spist.edu/auth/google/callback
GOOGLE_CLIENT_ID=your-production-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-production-client-secret
GOOGLE_CALLBACK_URL=https://library.spist.edu/auth/google/callback

# Security Secrets (CRITICAL - MUST CHANGE FOR PRODUCTION!)
#  Generate new secrets using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#  DO NOT use the development secrets in production!

# Session Secret - 64 character random hex string
SESSION_SECRET=GENERATE_NEW_64_CHARACTER_SECRET_HERE

# JWT Secret - 64 character random hex string  
JWT_SECRET=GENERATE_NEW_64_CHARACTER_SECRET_HERE

# Email Configuration (Production)
#  Use a professional email service, NOT Gmail
# Recommended: SendGrid, AWS SES, Mailgun, Postmark
EMAIL_USER=noreply@spist.edu
EMAIL_PASS=your-email-service-api-key
EMAIL_HOST=smtp.your-email-service.com
EMAIL_PORT=587

# Rate Limiting Configuration (Production - Stricter)
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=50

# Session Configuration (Production)
SESSION_MAX_AGE=1800000
SESSION_SECURE_COOKIE=true

# ============================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================
# [ ] All secrets generated and unique
# [ ] Database credentials updated
# [ ] Google OAuth configured for production domain
# [ ] Professional email service configured
# [ ] HTTPS/SSL certificates installed
# [ ] SESSION_SECURE_COOKIE set to true
# [ ] Firewall configured (ports 80, 443, 3000)
# [ ] Database backups automated
# [ ] PM2 configured for auto-restart
# [ ] Nginx reverse proxy configured
# [ ] Monitoring and logging enabled
# ============================================
