<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/img/school-logo-large.png" />
    <link rel="stylesheet" href="/css/auth-layout.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <title>Login Verification - SPIST Library</title>
  </head>
  <body>
    <div class="auth-container">
      <div class="image-panel" style="background-image: url('/img/schoolppp1.png');">
        <div class="image-content">
          <div class="logo-section">
            <a href="/" title="Go to Home">
              <img src="/img/school-logo-large.png" alt="SPIST Logo" />
            </a>
            <div class="logo-text">
              <h1>Southern Philippines Institute</h1>
              <h2>Institute of Science & Technology Tools</h2>
            </div>
          </div>
        </div>
      </div>

      <div class="green-panel">
        <div class="panel-content">
          <div class="decorative-line-top"></div>
          <div class="panel-header">
            <h1>Email Verification</h1>
          </div>
          <div class="decorative-line-middle"></div>

          <div class="password-requirements" style="text-align:left;">
            <p style="margin:0 0 8px 0;"><i class="fas fa-circle-info"></i> Please check your email inbox.</p>
            <p style="margin:0;">If your account requires verification, follow the instructions sent to your email address.</p>
          </div>

          <div class="button-group">
            <a href="/login" class="auth-button primary-button" style="text-align:center; text-decoration:none;">Back to Login</a>
            <a href="/signup" class="auth-button secondary-button" style="text-align:center; text-decoration:none;">Create Account</a>
          </div>

          <div class="decorative-line-bottom"></div>
        </div>
      </div>
    </div>
  </body>
</html>
