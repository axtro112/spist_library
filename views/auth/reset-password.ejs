<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/img/school-logo-large.png" />
    <link rel="stylesheet" href="/css/auth-layout.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <script src="/js/csrf-helper.js"></script>
    <script src="/js/reset-password.js" defer></script>
    <title>Reset Password - Southern Philippines Institute of Science &amp; Technology</title>
  </head>
  <body>
    <div class="auth-container">
      <div class="image-panel" style="background-image: url('/img/schoolppp1.png');">
        <div class="image-content">
          <div class="logo-section">
            <a href="/" title="Go to Home">
              <img src="/img/school-logo-large.png" alt="SPIST Logo" />
            </a>
            <div class="logo-text">
              <h1>Southern Philippines Institute</h1>
              <h2>Institute of Science & Technology Tools</h2>
            </div>
          </div>
        </div>
      </div>

      <div class="green-panel">
        <div class="panel-content">
          <div class="decorative-line-top"></div>
          <div class="panel-header">
            <h1>Reset Password</h1>
          </div>
          <div class="decorative-line-middle"></div>

          <div id="messageContainer" class="error-message" style="display:none;"></div>

          <form id="resetForm" class="auth-form">
            <div class="form-group">
              <label for="newPassword">New Password</label>
              <div class="password-input-wrapper">
                <input type="password" id="newPassword" name="newPassword" placeholder="Enter new password" required minlength="6" />
                <button type="button" class="toggle-password" onclick="togglePassword('newPassword')" aria-label="Toggle password visibility">
                  <i class="fas fa-eye"></i>
                </button>
              </div>
            </div>

            <div class="form-group">
              <label for="confirmPassword">Confirm Password</label>
              <div class="password-input-wrapper">
                <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Re-enter new password" required minlength="6" />
                <button type="button" class="toggle-password" onclick="togglePassword('confirmPassword')" aria-label="Toggle password visibility">
                  <i class="fas fa-eye"></i>
                </button>
              </div>
              <div id="matchIndicator" class="match-indicator" style="display:none;"></div>
            </div>

            <div class="password-requirements">
              <ul>
                <li id="req-length"><i class="fas fa-times"></i> At least 6 characters</li>
                <li id="req-match">Passwords must match</li>
              </ul>
            </div>

            <div id="loadingSpinner" style="display:none; text-align:center; margin-bottom:16px; color:#fff;">
              <i class="fas fa-spinner fa-spin"></i> Updating password...
            </div>

            <button id="submitBtn" type="submit" class="auth-button primary-button" disabled>
              Update Password
            </button>
          </form>

          <div class="auth-redirect">
            <p>Remembered your password? <a href="/login">Back to Login</a></p>
          </div>

          <div class="decorative-line-bottom"></div>
        </div>
      </div>
    </div>
  </body>
</html>

