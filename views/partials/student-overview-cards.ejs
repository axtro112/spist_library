<!-- ═══ Student Overview ═══ -->
<div class="u-stats-row student-overview-row">
  <div class="u-stat-card">
    <div class="u-stat-icon"><i class="bi bi-book-fill"></i></div>
    <div>
      <div class="u-stat-num" id="availableBooksCount">-</div>
      <div class="u-stat-label">Available Books</div>
    </div>
  </div>
  <div class="u-stat-card">
    <div class="u-stat-icon"><i class="bi bi-bookmark-fill"></i></div>
    <div>
      <div class="u-stat-num" id="borrowedBooksCount">-</div>
      <div class="u-stat-label">Borrowed Books</div>
    </div>
  </div>
  <div class="u-stat-card">
    <div class="u-stat-icon"><i class="bi bi-exclamation-triangle-fill" style="color:#fbbf24;"></i></div>
    <div>
      <div class="u-stat-num" id="dueSoonCount">-</div>
      <div class="u-stat-label">Due Soon</div>
    </div>
  </div>
  <div class="u-stat-card">
    <div class="u-stat-icon"><i class="bi bi-hourglass-split" style="color:#f59e0b;"></i></div>
    <div>
      <div class="u-stat-num" id="pendingBooksCount">-</div>
      <div class="u-stat-label">Pending Pickup</div>
    </div>
  </div>
</div>
