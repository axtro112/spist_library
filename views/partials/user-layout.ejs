<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title || 'SPIST Library' %></title>
  <link rel="icon" type="image/png" href="/img/school-logo-small.png" />

  <!-- Bootstrap 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
  <!-- Material Symbols -->
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <!-- Open Sans -->
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

  <!-- Core CSS -->
  <link rel="stylesheet" href="/css/common.css" />
  <link rel="stylesheet" href="/css/notifications.css" />
  <link rel="stylesheet" href="/css/user-theme.css" />

  <!-- Per-page extras (CSS, etc.) -->
  <%- extraHead || '' %>

  <!-- Core scripts -->
  <script src="/js/csrf-helper.js"></script>
  <script src="/js/session-timeout.js"></script>
  <script src="/js/api.js"></script>
  <script src="/js/ui.js"></script>
  <script src="/js/notifications.js"></script>
  <script src="/js/core/utils.js"></script>
</head>
<body class="ud-body">
<div class="ud-wrapper">

  <!-- ═══════════════ TOP NAVBAR ═══════════════ -->
  <nav class="ud-navbar" aria-label="Student navigation">

    <!-- Brand -->
    <div class="ud-navbar-brand">SPIST</div>

    <!-- Centre navigation links -->
    <div class="ud-navbar-center">
      <a href="/student-dashboard"
         class="ud-nav-link <%= activePage === 'dashboard' ? 'active' : '' %>">
        <i class="bi bi-grid-fill"></i>
        <span>Dashboard</span>
      </a>
      <a href="/student-books"
         class="ud-nav-link <%= activePage === 'books' ? 'active' : '' %>">
        <i class="bi bi-book-fill"></i>
        <span>Available Book</span>
      </a>
      <a href="/student-borrowed"
         class="ud-nav-link <%= activePage === 'borrowed' ? 'active' : '' %>">
        <i class="bi bi-calendar-event-fill"></i>
        <span>Due Soon</span>
      </a>
    </div>

    <!-- Right: user info + notification -->
    <div class="ud-navbar-right">
      <!-- Hidden profile text (JS sets these via setText) -->
      <div class="ud-profile-chip">
        <span class="ud-profile-name" id="userName">Student</span>
      </div>

      <!-- Notification bell — exact IDs required by notifications.js -->
      <div class="ud-notif-wrap" id="studentNotificationContainer">
        <button class="ud-notif-btn" id="studentNotifBell"
                title="Notifications" aria-label="Notifications"
                aria-expanded="false" role="button">
          <i class="bi bi-bell-fill"></i>
          <span class="ud-notif-badge" id="studentNotifBadge" style="display:none;">0</span>
        </button>

        <!-- Notification panel -->
        <div class="ud-notif-panel" id="studentNotifPanel" style="display:none;" role="menu">
          <div class="notif-header">
            <h3>Notifications</h3>
            <div class="notif-header-actions">
              <button class="notif-action-btn" id="notifMarkAllBtn" title="Mark all as read">
                <span class="material-symbols-outlined">done_all</span>
              </button>
              <button class="notif-action-btn" id="notifSettingsBtn" title="Settings">
                <span class="material-symbols-outlined">settings</span>
              </button>
            </div>
          </div>
          <div class="notif-tabs">
            <button class="notif-tab active" data-tab="all"    id="tabAll">All</button>
            <button class="notif-tab"        data-tab="unread" id="tabUnread">Unread</button>
          </div>
          <div class="notif-list-container" id="notifListContainer">
            <div class="notif-loading">Loading notifications…</div>
          </div>
          <div class="notif-footer">
            <button class="notif-see-more" id="notifSeeMore">See previous notifications</button>
          </div>
        </div>
      </div>
    </div>
  </nav>

  <!-- ═══════════════ PAGE CONTENT ═══════════════ -->
  <main class="ud-main">
    <%- body %>
  </main>

</div><!-- /.ud-wrapper -->

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<!-- Notification helpers -->
<script src="/js/notification-deeplink.js"></script>
<script src="/js/notification-highlight.js"></script>
<!-- Per-page scripts -->
<%- extraScripts || '' %>
</body>
</html>
