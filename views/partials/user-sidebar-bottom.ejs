    </main><!-- /.u-content -->
  </div><!-- /.u-main -->
</div><!-- /.u-wrapper -->

<!-- ═══ SHARED: Logout Modal ═══ -->
<div id="logoutModal" class="u-modal-overlay" style="display:none;">
  <div class="u-modal-box">
    <h2>Confirm Logout</h2>
    <p>Are you sure you want to log out?</p>
    <div class="u-modal-actions">
      <button class="u-btn-confirm" onclick="logout()">Logout</button>
      <button class="u-btn-cancel" onclick="closeLogoutModal()">Cancel</button>
    </div>
  </div>
</div>

