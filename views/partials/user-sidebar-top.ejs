<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle || 'Southern Philippines Institute of Science &amp; Technology' %></title>
  <link rel="icon" type="image/png" href="/img/school-logo-large.png" />

  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
  <!-- Material Symbols -->
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

  <link rel="stylesheet" href="/css/system.css" />

  <!-- Extra head content (per-page CSS/JS) -->
  <%- extraHead || '' %>

  <!-- Shared JS -->
  <script src="/js/csrf-helper.js"></script>
  <script src="/js/session-timeout.js"></script>
  <script src="/js/core/api.js"></script>
  <script src="/js/core/modal.js"></script>
  <script src="/js/api.js"></script>
  <script src="/js/ui.js"></script>
  <script src="/js/notifications.js?v=20260322"></script>
  <script src="/js/student/layout.js" defer></script>
  <script src="/js/user.js" defer></script>
  <script src="/js/sidebar-toggle.js" defer></script>
</head>
<body data-role="student" data-student-id="<%= studentId || '' %>" data-user-role="<%= userRole || '' %>">
<div class="u-wrapper">

  <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• SIDEBAR â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
  <aside class="u-sidebar" id="uSidebar">
    <div class="u-sidebar-brand">
      <img src="/img/school-logo-large.png" alt="SPIST Logo" />
      <div class="u-brand-text">
        <strong>SPIST</strong>
        <span>Library System</span>
      </div>
    </div>

    <nav class="u-nav">
      <a href="/student-dashboard" class="<%= activePage === 'dashboard' ? 'active' : '' %>">
        <i class="bi bi-speedometer2"></i><span>Dashboard</span>
      </a>
      <a href="/student-available" class="<%= activePage === 'available-books' ? 'active' : '' %>">
        <i class="bi bi-book-half"></i><span>Available Books</span>
      </a>
      <a href="/student-borrowed" class="<%= activePage === 'borrowed-books' ? 'active' : '' %>">
        <i class="bi bi-journal-bookmark-fill"></i><span>Borrowed Books</span>
      </a>
      <a href="#" onclick="showLogoutModal(); return false;" style="margin-top: auto;">
        <i class="bi bi-box-arrow-right"></i><span>Logout</span>
      </a>
    </nav>

    <div class="u-sidebar-footer">
    </div>
  </aside>

  <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• MAIN â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
  <div class="u-main">

    <!-- Top Header -->
    <header class="u-topbar">
      <div class="u-topbar-left">
        <div class="u-topbar-title">SPIST Library</div>
      </div>
      <div class="u-topbar-right">
        <!-- Notification Bell -->
        <div class="u-notif-container" id="studentNotificationContainer">
          <button class="u-notif-btn" id="studentNotifBell"
                  title="Notifications" aria-label="Notifications"
                  aria-expanded="false" role="button">
            <i class="bi bi-bell-fill"></i>
            <span class="u-notif-badge" id="studentNotifBadge" style="display:none;">0</span>
          </button>

          <div class="notif-panel" id="studentNotifPanel" style="display:none;" role="menu">
            <div class="notif-header">
              <h3>Notifications</h3>
              <div class="notif-header-actions">
                <button class="notif-action-btn" id="notifMarkAllBtn" title="Mark all as read">
                  <span class="material-symbols-outlined">done_all</span>
                </button>
                <button class="notif-action-btn" id="notifSettingsBtn" title="Settings">
                  <span class="material-symbols-outlined">settings</span>
                </button>
              </div>
            </div>
            <div class="notif-tabs">
              <button class="notif-tab active" data-tab="all" id="tabAll">All</button>
              <button class="notif-tab" data-tab="unread" id="tabUnread">Unread</button>
            </div>
            <div class="notif-list-container" id="notifListContainer">
              <div class="notif-loading">Loading notifications...</div>
            </div>
            <div class="notif-footer">
              <button class="notif-see-more" id="notifSeeMore">See previous notifications</button>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Page Content -->
    <main class="u-content">

