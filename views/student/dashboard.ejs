<%- include('../partials/user-sidebar-top', {
  pageTitle: 'Dashboard - SPIST Library',
  activePage: 'dashboard',
  extraHead: '<script src="/js/core/utils.js"><\/script><script src="/js/student/dashboard.js" defer><\/script><script>document.addEventListener("DOMContentLoaded",function(){if(window.Student&&Student.Dashboard)Student.Dashboard.init();});<\/script>'
}) %>

<!-- Hidden compat spans — dashboard.js uses Core.utils.setText() on these -->
<span id="userNameHeading" style="display:none;"></span>

<!-- ═══ Stat Cards ═══ -->
<div class="u-stats-row">
  <div class="u-stat-card">
    <div class="u-stat-icon"><i class="bi bi-book-fill"></i></div>
    <div>
      <div class="u-stat-num" id="availableBooksCount">—</div>
      <div class="u-stat-label">Available Books</div>
    </div>
  </div>
  <div class="u-stat-card">
    <div class="u-stat-icon"><i class="bi bi-bookmark-fill"></i></div>
    <div>
      <div class="u-stat-num" id="borrowedBooksCount">—</div>
      <div class="u-stat-label">Borrowed Books</div>
    </div>
  </div>
  <div class="u-stat-card">
    <div class="u-stat-icon"><i class="bi bi-exclamation-triangle-fill" style="color:#fbbf24;"></i></div>
    <div>
      <div class="u-stat-num" id="dueSoonCount">—</div>
      <div class="u-stat-label">Due Soon</div>
    </div>
  </div>
</div>

<!-- ═══ Top Choices + Calendar ═══ -->
<div class="u-grid-2col">

  <!-- Top Choices — populated by dashboard.js updateRecommendedBooks() -->
  <div class="u-panel">
    <h3 class="u-panel-title">Top Choices</h3>
    <div class="u-table-wrap">
      <table class="u-table">
        <thead>
          <tr>
            <th>Book Title</th>
            <th>Author</th>
            <th>Category</th>
            <th>Status</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody id="recommendedBooksTableBody">
          <tr><td colspan="5" class="text-center">Loading recommendations…</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Calendar -->
  <div class="u-panel">
    <h3 class="u-panel-title">Calendar</h3>
    <div class="u-calendar-placeholder" id="calendarPlaceholder">Calendar coming soon</div>
  </div>

</div>

<!-- ═══ Currently Borrowed Books ═══ -->
<div class="u-panel">
  <div class="u-panel-header">
    <h3 class="u-panel-title">Book List</h3>
    <a class="u-see-all" href="/student-borrowed">see all</a>
  </div>
  <div class="u-table-wrap">
    <table class="u-table">
      <thead>
        <tr>
          <th>Book Title</th>
          <th>Author</th>
          <th>Borrowed Date</th>
          <th>Due Date</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody id="borrowedBooksTableBody">
        <tr><td colspan="5" class="text-center">Loading borrowed books…</td></tr>
      </tbody>
    </table>
  </div>
</div>

<!-- ═══ Borrow Confirmation Modal (ID "modal-user" — required by dashboard.js) ═══ -->
<div id="modal-user" class="u-modal-overlay" style="display:none;">
  <div class="u-modal-box">
    <h2>Confirm Book Borrowing</h2>
    <p id="borrowConfirmMessage">Are you sure you want to borrow this book?</p>
    <div class="u-form-group">
      <label for="returnDate">Select Return Date:</label>
      <input type="date" id="returnDate" class="u-date-input" required />
    </div>
    <div class="u-modal-actions">
      <button type="button" class="u-btn-confirm" onclick="handleBorrow()">Confirm</button>
      <button type="button" class="u-btn-cancel" onclick="closeModal()">Cancel</button>
    </div>
  </div>
</div>

<%- include('../partials/user-sidebar-bottom') %>
