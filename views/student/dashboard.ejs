<%- include('../partials/user-sidebar-top', {
  pageTitle: 'Dashboard - SPIST Library',
  studentId: studentId,
  userRole: userRole,
  activePage: 'dashboard',
  extraHead: '<link rel="stylesheet" href="/css/student/quick-borrow.css"><script src="/js/student/quick-borrow-modal.js"><\/script><script src="/js/core/utils.js"><\/script><script src="/js/student/dashboard.js" defer><\/script>'
}) %>

<!-- Hidden compat spans — dashboard.js uses Core.utils.setText() on these -->
<span id="userNameHeading" style="display:none;"></span>

<%- include('../partials/student-overview-cards') %>

<!-- ═══ Frequently Borrowed Books ═══ -->
<div class="u-panel">
  <div class="u-panel-header">
    <h3 class="u-panel-title">Top Choices</h3>
    <a class="u-see-all" href="/student-available">see all</a>
  </div>
  <div class="u-table-wrap">
    <table class="u-table">
      <thead>
        <tr>
          <th style="width:50px;">ID</th>
          <th>Title</th>
          <th>Author</th>
          <th>Category</th>
          <th>ISBN</th>
          <th style="width:100px;text-align:center;">Available</th>
          <th style="width:120px;">Action</th>
        </tr>
      </thead>
      <tbody id="frequentlyBorrowedTableBody">
        <tr><td colspan="7" class="text-center" style="padding:20px;color:#888;">Loading frequently borrowed books…</td></tr>
      </tbody>
    </table>
  </div>
</div>

<!-- ═══ Book List + Calendar ═══ -->
<div class="u-grid-2col">

  <!-- Currently Borrowed Books -->
  <div class="u-panel">
    <div class="u-panel-header">
      <h3 class="u-panel-title">Borrowed Books</h3>
      <a class="u-see-all" href="/student-borrowed">see all</a>
    </div>
    <div class="u-table-wrap">
      <table class="u-table">
        <thead>
          <tr>
            <th>Book Title</th>
            <th>Author</th>
            <th>Borrowed Date</th>
            <th>Due Date</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody id="borrowedBooksTableBody">
          <tr><td colspan="5" class="text-center">Loading borrowed books…</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Calendar -->
  <div class="u-panel">
    <h3 class="u-panel-title">Calendar</h3>
    <div id="calendarPlaceholder"></div>
  </div>

</div>

<%- include('../partials/quick-borrow-modal') %>

<%- include('../partials/user-sidebar-bottom') %>
