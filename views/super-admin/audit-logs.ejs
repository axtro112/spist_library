<%
  var extraHead = '<script src="/js/admin/audit.js" defer><\/script>';
%>
<%- include('../partials/super-admin-layout', {
  title: 'Audit Logs - SPIST Library (Super Admin)',
  adminEmail: adminEmail,
  adminId: adminId,
  adminRole: adminRole,
  activePage: 'audit',
  extraHead: extraHead,
  body: `
    <div class="section-header">
      <div>
        <h1>Audit Logs</h1>
        <p>System activity and change history</p>
      </div>
    </div>

    <div class="section-card">
      <div style="padding: 60px 40px; text-align: center;">
        <i class="bi bi-clock-history" style="font-size: 64px; color: #0e5e3f; opacity: 0.5;"></i>
        <h3 style="color: #374151; margin-top: 20px; font-weight: 600;">Audit Logs Feature</h3>
        <p style="color: #6b7280; margin-top: 10px;">
          This feature will display system activity logs including:
        </p>
        <ul style="list-style: none; padding: 0; color: #9ca3af; margin-top: 15px; line-height: 2;">
          <li><i class="bi bi-dot"></i> Admin login/logout activities</li>
          <li><i class="bi bi-dot"></i> Book management changes</li>
          <li><i class="bi bi-dot"></i> User management actions</li>
          <li><i class="bi bi-dot"></i> System configuration updates</li>
        </ul>
        <p style="color: #9ca3af; margin-top: 20px; font-style: italic;">Coming soon...</p>
      </div>
    </div>
  `
}) %>
