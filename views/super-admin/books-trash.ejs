<%
  var extraHead = '<script src="/js/trash-manager.js" defer><\/script><script src="/js/super-admin/books-trash.js" defer><\/script>';
%>
<%- include('../partials/super-admin-layout', {
  title: 'Books Trash - Southern Philippines Institute of Science & Technology',
  adminEmail: adminEmail,
  adminId: adminId,
  adminRole: adminRole,
  activePage: 'books-trash',
  extraHead: extraHead,
  body: `
    <div class="section-header">
      <h2><i class="bi bi-trash me-2"></i>Books Trash</h2>
    </div>

    <div class="section-card">
      <div class="sa-filter-bar">
        <div class="sa-search-wrap">
          <i class="bi bi-search"></i>
          <input type="text" id="searchInput" placeholder="Search by title, author, ISBN..." />
        </div>
        <select id="categoryFilter" class="sa-filter-select">
          <option value="">All Categories</option>
        </select>
        <button id="clearFilters" class="sa-clear-btn">
          <i class="bi bi-x-circle me-1"></i>Clear
        </button>
      </div>

      <div class="sa-bulk-bar">
        <div class="d-flex align-items-center gap-2">
          <input type="checkbox" id="bulkMasterCheckbox" class="form-check-input" />
          <span id="bulkSelectionText" class="small fw-medium text-secondary"></span>
        </div>
        <div class="d-flex gap-2">
          <button id="bulkRestoreBtn" class="sa-btn sa-btn-success" disabled>
            <i class="bi bi-arrow-counterclockwise me-1"></i>Restore
          </button>
          <button id="bulkDeleteBtn" class="sa-btn sa-btn-danger" disabled>
            <i class="bi bi-trash3-fill me-1"></i>Delete Forever
          </button>
        </div>
      </div>

      <div class="sa-table-wrapper">
        <table class="user-table">
          <thead>
            <tr>
              <th class="checkbox-col"></th>
              <th>ID</th>
              <th>Title</th>
              <th>Author</th>
              <th>Copies</th>
              <th>Category</th>
              <th>ISBN</th>
              <th>Deleted At</th>
              <th>Deleted By</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td colspan="10" style="text-align:center;padding:40px;">
                <div class="notif-loading">Loading trash...</div>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  `
}) %>


