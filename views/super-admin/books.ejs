<%
  var extraHead = '<script src="/js/admin/books.js" defer><\/script><script src="/js/admin.js" defer><\/script><script src="/js/books.js" defer><\/script><script src="/js/book-copies.js" defer><\/script><script src="/js/books-import-export.js" defer><\/script><script src="/js/bulk-operations.js" defer><\/script><script src="/js/books-lifecycle-tabs.js" defer><\/script><script src="/js/book-details-modal.js" defer><\/script><script src="/js/super-admin/books.js" defer><\/script><script src="/js/super-admin/overview.js" defer><\/script>';
%>
<%- include('../partials/super-admin-layout', {
  title: 'Book Management - SPIST Library',
  adminEmail: adminEmail,
  adminId: adminId,
  adminRole: adminRole,
  activePage: 'books',
  extraHead: extraHead,
  body: `
    <div class="section-header d-flex align-items-center justify-content-between flex-wrap gap-3">
      <div>
        <h2><i class="bi bi-book me-2"></i>Book Management</h2>
      </div>
      <div class="d-flex gap-2 flex-wrap">
        <button class="sa-btn sa-btn-success" onclick="showModal('adminModal')">
          <i class="bi bi-plus-circle me-1"></i>Add Book
        </button>
        <button class="sa-btn sa-btn-primary" onclick="showModal('importModal')">
          <i class="bi bi-upload me-1"></i>Import File
        </button>
        <div class="dropdown-container">
          <button class="sa-btn sa-btn-outline dropdown-toggle" onclick="toggleExportDropdown(event)">
            <i class="bi bi-download me-1"></i>Download <i class="bi bi-chevron-down ms-1"></i>
          </button>
          <div class="dropdown-menu" id="exportDropdown">
            <a href="javascript:void(0)" onclick="exportBooksCSV()">
              <span class="material-symbols-outlined">description</span>
              <div class="dropdown-text">
                <span class="dropdown-title">Plain Text (.txt)</span>
                <span class="dropdown-subtitle">CSV format</span>
              </div>
            </a>
            <a href="javascript:void(0)" onclick="exportBooks()">
              <span class="material-symbols-outlined">table_chart</span>
              <div class="dropdown-text">
                <span class="dropdown-title">Microsoft Word (.docx)</span>
                <span class="dropdown-subtitle">Excel format</span>
              </div>
            </a>
            <a href="javascript:void(0)" onclick="downloadTemplate()">
              <span class="material-symbols-outlined">file_download</span>
              <div class="dropdown-text">
                <span class="dropdown-title">OpenDocument Format (.odt)</span>
                <span class="dropdown-subtitle">Import template</span>
              </div>
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="section-card">
      <div class="sa-filter-bar">
        <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">
          <input type="checkbox" id="bulkMasterCheckbox" class="form-check-input" style="width:18px;height:18px;cursor:pointer;" title="Select all" />
          <span id="bulkSelectionText" class="small fw-medium text-secondary" style="white-space:nowrap;"></span>
        </div>
        <div class="sa-search-wrap" style="flex:1;min-width:200px;">
          <i class="bi bi-search"></i>
          <input type="text" id="searchInput" placeholder="Search by title, author, ISBN, or category..." />
        </div>
        <select id="categoryFilter" class="sa-filter-select">
          <option value="">All Categories</option>
        </select>
        <select id="statusFilter" class="sa-filter-select">
          <option value="">All Status</option>
          <option value="Available">Available</option>
          <option value="All Borrowed">Borrowed</option>
          <option value="maintenance">Maintenance</option>
        </select>
          <button id="clearFilters" class="sa-clear-btn" title="Clear all filters">
          <i class="bi bi-funnel-fill"></i> Clear
        </button>
        <button id="bulkEditBtn" class="sa-btn sa-btn-primary" title="Edit selected books" disabled>
          <i class="bi bi-pencil-fill me-1"></i>Edit
        </button>
        <button id="bulkDeleteBtn" class="sa-btn sa-btn-danger" title="Delete selected books" disabled>
          <i class="bi bi-trash-fill me-1"></i>Delete
        </button>
      </div>

      <div class="d-flex align-items-center mb-2">
        <span id="resultCount" class="result-count">Showing 0 of 0 books</span>
      </div>

      <div class="books-lifecycle-tabs" data-component="books-tabs">
        <button type="button" class="books-tab active" data-tab="all">
          All Books
          <span class="tab-badge" id="count-all">0</span>
        </button>
        <button type="button" class="books-tab" data-tab="active">
          Active Books
          <span class="tab-badge" id="count-active">0</span>
        </button>
        <button type="button" class="books-tab overdue-tab" data-tab="overdue">
          Overdue Books
          <span class="tab-badge overdue-badge" id="count-overdue">0</span>
        </button>
      </div>

      <div class="sa-table-wrapper" data-books-table-wrapper>
        <table class="user-table">
          <thead>
            <tr>
              <th class="checkbox-col"></th>
              <th>ID</th>
              <th>Title</th>
              <th>Author</th>
              <th>Quantity</th>
              <th>Category</th>
              <th>ISBN</th>
              <th>Added Date</th>
              <th>Status</th>
              <th>Rented by</th>
              <th></th>
            </tr>
          </thead>
          <tbody></tbody>
        </table>
      </div>
    </div>

    <!-- Add Book Modal (METADATA ONLY) -->
    <!-- This modal creates/updates book metadata (title/author/isbn/category/status) -->
    <!-- Individual copy/accession management is handled via Manage Copies (see book-copies.js) -->
    <div id="adminModal" class="modal">
      <div class="modal-content">
        <h2>Add New Book</h2>
        <form id="addBookForm" method="POST">
          <div class="form-group">
            <label for="title">Title <span style="color:#e53e3e;">*</span></label>
            <input type="text" id="title" name="title" required placeholder="Enter book title" />
          </div>
          <div class="form-group">
            <label for="author">Author <span style="color:#e53e3e;">*</span></label>
            <input type="text" id="author" name="author" required placeholder="Enter author name" />
          </div>
          <div class="form-group">
            <label for="No#Books">Initial Quantity <span style="color:#999;font-size:0.85rem;font-weight:normal;">(copies and accession numbers will be auto-generated)</span></label>
            <input type="number" id="No#Books" name="No#Books" value="1" min="0" max="999" />
          </div>
          <div class="form-group">
            <label for="category">Category <span style="color:#e53e3e;">*</span></label>
            <input type="text" id="category" name="category" required placeholder="Enter category (e.g., Fiction, Science)" />
          </div>
          <div class="form-group">
            <label for="isbn">ISBN / Barcode <span style="color:#e53e3e;">*</span></label>
            <input type="text" id="isbn" name="isbn" required placeholder="Enter ISBN-10, ISBN-13, or barcode" />
          </div>
          <div class="form-group">
            <label for="status">Status <span style="color:#e53e3e;">*</span></label>
            <select id="status" name="status" required>
              <option value="">-- Select Status --</option>
              <option value="available" selected>Available</option>
              <option value="maintenance">Maintenance</option>
              <option value="retired">Retired</option>
            </select>
          </div>
          <div class="form-actions">
            <button type="submit" class="submit-btn">Add Book</button>
            <button type="button" class="cancel-btn" onclick="closeModal()">Cancel</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Edit Book Modal — form fields moved into merged #copiesModal (book-copies.js) -->
    <div id="adminEdit" style="display:none" hidden></div>

    <!-- Delete Confirmation Modal -->
    <div id="modalDelete" class="modal">
      <div class="modal-content">
        <h2>Confirm Deletion</h2>
        <p>Are you sure you want to delete this book?</p>
        <div class="form-actions">
          <button type="button" class="delete-confirm-btn">Delete</button>
          <button type="button" class="cancel-btn" onclick="closeModal()">Cancel</button>
        </div>
      </div>
    </div>

    <!-- Import Books Modal -->
    <div id="importModal" class="modal">
      <div class="modal-content modal-content-wide">
        <h2>Import Books from CSV or Excel</h2>
        <form id="importForm" enctype="multipart/form-data">
          <div class="form-group">
            <label for="csvFile">Select CSV or Excel File</label>
            <input type="file" id="csvFile" name="csvFile" accept=".csv,.xlsx,.xls,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel" required />
            <div class="csv-format-info">
              <strong><span class="material-symbols-outlined icon-inline">info</span> File Format Requirements (CSV or Excel)</strong>
              <div class="csv-format-details">
                <div class="csv-format-section">
                  <strong>Required columns (in order):</strong><br>
                  <code class="csv-format-code">title,author,isbn,category,quantity</code>
                </div>
                <div class="csv-format-rules"><strong>Validation Rules:</strong></div>
                <ul class="csv-format-list">
                  <li><strong>Required fields:</strong> title, author, isbn, category (rows with missing fields will be skipped)</li>
                  <li><strong>Quantity:</strong> Defaults to 1 if empty; use 0 for borrowed/missing books</li>
                  <li><strong>Duplicate ISBNs:</strong> Rows with ISBNs already in the database will be skipped</li>
                  <li><strong>Status rules:</strong> Quantity &ge; 1 = "available"; Quantity = 0 = "borrowed" or "missing" based on borrowing records</li>
                </ul>
              </div>
            </div>
          </div>
          <div id="importProgress" class="import-progress">
            <label>Upload Progress</label>
            <div class="progress-bar-container">
              <div id="importProgressBar" class="progress-bar">0%</div>
            </div>
          </div>
          <div id="importResults" class="import-results">
            <h4>Import Results</h4>
            <div id="importResultsContent"></div>
          </div>
          <div class="form-actions">
            <button type="submit" class="submit-btn" id="importSubmitBtn">
              <span class="material-symbols-outlined icon-inline">upload_file</span>Import Books
            </button>
            <button type="button" class="cancel-btn" onclick="closeModal(); resetImportForm();">Cancel</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Bulk Edit Modal -->
    <div id="bulkEditModal" class="modal">
      <div class="modal-content">
        <h2>Edit Selected Books</h2>
        <form id="bulkEditForm" onsubmit="handleBulkEditSubmit(event)">
          <div class="form-group">
            <label for="bulkCategory">Category</label>
            <input type="text" id="bulkCategory" name="category" placeholder="Leave empty to keep unchanged" />
            <div class="field-note">Apply new category to all selected books</div>
          </div>
          <div class="form-group">
            <label for="bulkStatus">Status</label>
            <select id="bulkStatus" name="status">
              <option value="">-- Keep unchanged --</option>
              <option value="available">Available</option>
              <option value="borrowed">Borrowed</option>
              <option value="maintenance">Maintenance</option>
            </select>
            <div class="field-note">Update status for all selected books</div>
          </div>
          <div class="form-group">
            <label for="bulkQuantity">Quantity</label>
            <input type="number" id="bulkQuantity" name="quantity" min="0" placeholder="Leave empty to keep unchanged" />
            <div class="field-note">Set quantity for all selected books</div>
          </div>
          <div class="form-actions">
            <button type="submit" class="submit-btn">Update Books</button>
            <button type="button" class="cancel-btn" onclick="closeModal()">Cancel</button>
          </div>
        </form>
      </div>
    </div>


  `
}) %>
