        </p>
        <ul style="list-style: none; padding: 0; color: #9ca3af; margin-top: 15px; line-height: 2;">
          <li><i class="bi bi-dot"></i> Database backup and restore</li>
          <li><i class="bi bi-dot"></i> Email notification settings</li>
          <li><i class="bi bi-dot"></i> Library operating hours</li>
          <li><i class="bi bi-dot"></i> Late fee configuration</li>
          <li><i class="bi bi-dot"></i> System maintenance mode</li>
        </ul>
        <p style="color: #9ca3af; margin-top: 20px; font-style: italic;">Coming soon...</p>
      </div>
    </div>
  `
}) %>
