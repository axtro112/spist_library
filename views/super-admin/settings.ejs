<%
  var extraHead = '<style>html,body{overflow:hidden!important;height:100%!important;}.sa-wrapper{height:100vh;overflow:hidden;}.sa-main{min-height:unset!important;height:100vh;overflow:hidden;}.sa-content{height:calc(100vh - var(--sa-header-h));overflow-y:auto!important;overflow-x:hidden;}<\/style>';
%>
<%- include('../partials/super-admin-layout', {
  title: 'System Settings - SPIST Library (Super Admin)',
  adminEmail: adminEmail,
  activePage: 'settings',
  extraHead: extraHead,
  body: `
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        var s = SuperAdmin.utils.getSession();
        SuperAdmin.utils.loadAdminHeader(s.adminId);
      });
    <\/script>

    <div class="section-header">
      <div>
        <h1>System Settings</h1>
        <p>Configure library system options</p>
      </div>
    </div>

    <div class="section-card">
      <div style="padding: 60px 40px; text-align: center;">
        <i class="bi bi-gear-fill" style="font-size: 64px; color: #0e5e3f; opacity: 0.5;"></i>
        <h3 style="color: #374151; margin-top: 20px; font-weight: 600;">System Settings</h3>
        <p style="color: #6b7280; margin-top: 10px;">
