<%
  var extraHead = '<link rel="stylesheet" href="/css/super-admin/bulk-operations.css"><link rel="stylesheet" href="/css/super-admin/trash.css"><script src="/js/trash-manager.js" defer><\/script><script src="/js/super-admin/users-trash.js" defer><\/script><style>html,body{overflow:hidden!important;height:100%!important;}.sa-wrapper{height:100vh;overflow:hidden;}.sa-main{min-height:unset!important;height:100vh;overflow:hidden;}.sa-content{height:calc(100vh - var(--sa-header-h));overflow-y:auto!important;overflow-x:hidden;}<\/style>';
%>
<%- include('../partials/super-admin-layout', {
  title: 'Users Trash - SPIST Library',
  adminEmail: adminEmail,
  activePage: 'users-trash',
  extraHead: extraHead,
  body: `
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        SuperAdmin.UsersTrashPage.init();
      });
    <\/script>

    <div class="section-header">
      <div>
        <h2><i class="bi bi-trash me-2"></i>Users Trash</h2>
      </div>
    </div>

    <div class="section-card">
      <div class="sa-filter-bar mb-3">
        <div class="sa-search-wrap">
          <i class="bi bi-search"></i>
          <input type="text" id="searchInput" class="sa-filter-select" style="min-width:260px;" placeholder="Search by name, student ID, email..." />
        </div>
        <select id="departmentFilter" class="sa-filter-select">
          <option value="">All Departments</option>
          <option value="BSIT">BSIT</option>
          <option value="BSCS">BSCS</option>
          <option value="BSIS">BSIS</option>
          <option value="BSEMC">BSEMC</option>
        </select>
        <select id="yearLevelFilter" class="sa-filter-select">
          <option value="">All Year Levels</option>
          <option value="1">1st Year</option>
          <option value="2">2nd Year</option>
          <option value="3">3rd Year</option>
          <option value="4">4th Year</option>
        </select>
        <select id="statusFilter" class="sa-filter-select">
          <option value="">All Status</option>
          <option value="active">Active</option>
          <option value="inactive">Inactive</option>
        </select>
        <button id="clearFilters" class="sa-clear-btn"><i class="bi bi-x-circle me-1"></i>Clear</button>
      </div>

      <div class="sa-bulk-bar mb-3">
        <div class="d-flex align-items-center gap-2">
          <input type="checkbox" id="bulkMasterCheckbox" class="bulk-master-checkbox" />
          <span id="bulkSelectionText" class="bulk-selection-text" style="display:none;"></span>
        </div>
        <div class="d-flex gap-2">
          <button id="bulkRestoreBtn" class="sa-btn sa-btn-success" disabled>
            <i class="bi bi-arrow-counterclockwise me-1"></i>Restore
          </button>
          <button id="bulkDeleteBtn" class="sa-btn sa-btn-danger" disabled>
            <i class="bi bi-trash3 me-1"></i>Delete Forever
          </button>
        </div>
      </div>

      <div class="sa-table-wrapper">
        <table class="user-table w-100">
          <thead>
            <tr>
              <th class="checkbox-col"><input type="checkbox" style="visibility:hidden;"></th>
              <th>ID</th>
              <th>Student ID</th>
              <th>Name</th>
              <th>Email</th>
              <th>Department</th>
              <th>Year Level</th>
              <th>Status</th>
              <th>Deleted At</th>
              <th>History</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td colspan="11" style="text-align:center;padding:40px;">
                <div class="notif-loading">Loading trash...</div>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  `
}) %>
