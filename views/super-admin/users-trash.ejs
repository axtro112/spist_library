<%
  var extraHead = '<script src="/js/trash-manager.js" defer><\/script><script src="/js/super-admin/users-trash.js" defer><\/script>';
%>
<%- include('../partials/super-admin-layout', {
  title: 'Users Trash - Southern Philippines Institute of Science & Technology',
  adminEmail: adminEmail,
  adminId: adminId,
  adminRole: adminRole,
  activePage: 'users-trash',
  extraHead: extraHead,
  body: `
    <div class="section-header">
      <div>
        <h2><i class="bi bi-trash me-2"></i>Users Trash</h2>
      </div>
    </div>

    <div class="section-card">
      <div class="sa-filter-bar mb-3">
        <div class="sa-search-wrap">
          <i class="bi bi-search"></i>
          <input type="text" id="searchInput" class="sa-filter-select" style="min-width:260px;" placeholder="Search by name, student ID, email..." />
        </div>
        <select id="departmentFilter" class="sa-filter-select">
          <option value="">All Departments</option>
          <option value="BS Computer Engineering">BS Computer Engineering</option>
          <option value="BS Computer Science">BS Computer Science</option>
          <option value="BS Information Technology">BS Information Technology</option>
          <option value="BS Tourism Management">BS Tourism Management</option>
          <option value="BS Business Administration - Major in Marketing Management">BSBA - Marketing Management</option>
          <option value="BS Business Administration - Major in Operations Management">BSBA - Operations Management</option>
          <option value="BS Accountancy">BS Accountancy</option>
          <option value="BS Hospitality Management">BS Hospitality Management</option>
          <option value="Bachelor in Elementary Education">BEEd</option>
          <option value="Bachelor in Secondary Education - Major in English">BSEd - English</option>
          <option value="Bachelor in Secondary Education - Major in Mathematics">BSEd - Mathematics</option>
          <option value="Bachelor in Secondary Education - Major in Filipino">BSEd - Filipino</option>
          <option value="Bachelor in Secondary Education - Major in Social Studies">BSEd - Social Studies</option>
          <option value="Bachelor in Secondary Education - Major in Science">BSEd - Science</option>
        </select>
        <select id="yearLevelFilter" class="sa-filter-select">
          <option value="">All Year Levels</option>
          <option value="1">1st Year</option>
          <option value="2">2nd Year</option>
          <option value="3">3rd Year</option>
          <option value="4">4th Year</option>
        </select>
        <select id="statusFilter" class="sa-filter-select">
          <option value="">All Status</option>
          <option value="active">Active</option>
          <option value="inactive">Inactive</option>
        </select>
        <button id="clearFilters" class="sa-clear-btn"><i class="bi bi-x-circle me-1"></i>Clear</button>
      </div>

      <div class="sa-bulk-bar mb-3">
        <div class="d-flex align-items-center gap-2">
          <input type="checkbox" id="bulkMasterCheckbox" class="bulk-master-checkbox" />
          <span id="bulkSelectionText" class="bulk-selection-text" style="display:none;"></span>
        </div>
        <div class="d-flex gap-2">
          <button id="bulkRestoreBtn" class="sa-btn sa-btn-success" disabled>
            <i class="bi bi-arrow-counterclockwise me-1"></i>Restore
          </button>
          <button id="bulkDeleteBtn" class="sa-btn sa-btn-danger" disabled>
            <i class="bi bi-trash3 me-1"></i>Delete Forever
          </button>
        </div>
      </div>

      <div class="sa-table-wrapper">
        <table class="user-table w-100">
          <thead>
            <tr>
              <th class="checkbox-col"><input type="checkbox" style="visibility:hidden;"></th>
              <th>ID</th>
              <th>Student ID</th>
              <th>Name</th>
              <th>Email</th>
              <th>Department</th>
              <th>Year Level</th>
              <th>Status</th>
              <th>Deleted At</th>
              <th>History</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td colspan="11" style="text-align:center;padding:40px;">
                <div class="notif-loading">Loading trash...</div>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  `
}) %>

