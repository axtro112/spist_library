          <button type="button" class="sa-modal-close-btn" onclick="closeEditUserModal()" aria-label="Close">&times;</button>
        </div>
        <form id="editUserForm" novalidate>
          <div class="sa-modal-body">
            <div id="editUserError" class="sa-modal-error" role="alert" style="display:none;"></div>
            <div class="sa-form-group">
              <label for="editUserFullname">Full Name <span class="req">*</span></label>
              <input type="text" id="editUserFullname" required placeholder="Enter full name" maxlength="100" />
            </div>
            <div class="sa-form-group">
