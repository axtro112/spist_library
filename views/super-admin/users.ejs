    </div>

    <div id="adminModal" class="modal sa-modal" role="dialog" aria-modal="true" aria-labelledby="addUserModalTitle">
      <div class="sa-modal-content">
        <div class="sa-modal-header">
          <h2 id="addUserModalTitle"><span class="material-symbols-outlined">person_add</span> Add New User</h2>
          <button type="button" class="sa-modal-close-btn" onclick="closeAddUserModal()" aria-label="Close">&times;</button>
        </div>
        <form id="addUserForm" novalidate>
          <div class="sa-modal-body">
            <div id="addUserError" class="sa-modal-error" role="alert" style="display:none;"></div>
            <div class="sa-form-group sa-col-full">
              <label for="addUserFullname">Full Name <span class="req">*</span></label>
              <input type="text" id="addUserFullname" required placeholder="Enter full name" maxlength="100" />
            </div>
            <div class="sa-form-group">
              <label for="addUserStudentId">Student ID <span class="req">*</span></label>
              <input type="text" id="addUserStudentId" required placeholder="e.g. cxx-xxxx-xx" maxlength="20" />
            </div>
            <div class="sa-form-group sa-col-full">
              <label for="addUserEmail">Email Address <span class="req">*</span></label>
              <input type="email" id="addUserEmail" required placeholder="Enter email address" />
            </div>
            <div class="sa-form-group">
              <label for="addUserStage">Education Stage <span class="req">*</span></label>
              <select id="addUserStage" required>
                <option value="Pre-School">Pre-School</option>
                <option value="Prep">Prep</option>
                <option value="Kinder">Kinder</option>
                <option value="Elementary">Elementary</option>
                <option value="Junior High">Junior High</option>
                <option value="Senior High">Senior High</option>
                <option value="College" selected>College</option>
              </select>
            </div>
            <div class="sa-form-group">
              <label for="addUserPassword">Password <span class="req">*</span></label>
              <div class="sa-password-wrap">
                <input type="password" id="addUserPassword" required placeholder="Minimum 6 characters" />
                <button type="button" class="sa-eye-toggle" id="toggleAddUserPassword" tabindex="-1" aria-label="Toggle password visibility">
                  <span class="material-symbols-outlined" id="eyeAddUserPassword">visibility</span>
                </button>
              </div>
            </div>
            <div class="sa-form-group">
              <label for="addUserConfirmPassword">Re-enter Password <span class="req">*</span></label>
              <div class="sa-password-wrap">
                <input type="password" id="addUserConfirmPassword" required placeholder="Re-enter password" />
                <button type="button" class="sa-eye-toggle" id="toggleAddUserConfirmPassword" tabindex="-1" aria-label="Toggle confirm password visibility">
                  <span class="material-symbols-outlined" id="eyeAddUserConfirmPassword">visibility</span>
                </button>
              </div>
            </div>
            <div class="sa-form-group">
              <label for="addUserDept">Program / Course</label>
              <select id="addUserDept">
                <option value="">-- Select program or course --</option>
                <option value="BS Computer Engineering">BS Computer Engineering</option>
                <option value="BS Computer Science">BS Computer Science</option>
                <option value="BS Information Technology">BS Information Technology</option>
                <option value="BS Tourism Management">BS Tourism Management</option>
                <option value="BS Business Administration - Major in Marketing Management">BS Business Administration - Major in Marketing Management</option>
                <option value="BS Business Administration - Major in Operations Management">BS Business Administration - Major in Operations Management</option>
                <option value="BS Accountancy">BS Accountancy</option>
                <option value="BS Hospitality Management">BS Hospitality Management</option>
                <option value="Bachelor in Elementary Education">Bachelor in Elementary Education</option>
                <option value="Bachelor in Secondary Education - Major in English">Bachelor in Secondary Education - Major in English</option>
                <option value="Bachelor in Secondary Education - Major in Mathematics">Bachelor in Secondary Education - Major in Mathematics</option>
                <option value="Bachelor in Secondary Education - Major in Filipino">Bachelor in Secondary Education - Major in Filipino</option>
                <option value="Bachelor in Secondary Education - Major in Social Studies">Bachelor in Secondary Education - Major in Social Studies</option>
                <option value="Bachelor in Secondary Education - Major in Science">Bachelor in Secondary Education - Major in Science</option>
              </select>
            </div>
            <div class="sa-form-group">
              <label for="addUserYear">Year Level <span class="req">*</span></label>
              <select id="addUserYear">
                <option value="">-- Select year level --</option>
              </select>
            </div>
          </div>
          <div class="sa-modal-footer">
            <button type="submit" class="sa-btn sa-btn-success">
              <i class="bi bi-person-check-fill me-1"></i> Add User
            </button>
            <button type="button" class="sa-btn sa-btn-outline cancel-btn" onclick="closeAddUserModal()">Cancel</button>
          </div>
        </form>
      </div>
    </div>

    <div id="adminEdit" class="modal sa-modal" role="dialog" aria-modal="true" aria-labelledby="editUserModalTitle">
      <div class="sa-modal-content">
        <div class="sa-modal-header">
