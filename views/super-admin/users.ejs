            </button>
            <button type="button" class="sa-btn sa-btn-outline cancel-btn" onclick="closeEditUserModal()">Cancel</button>
          </div>
        </form>
      </div>
    </div>

    <div id="modalDelete" class="modal sa-modal" role="dialog" aria-modal="true" aria-labelledby="deleteUserModalTitle">
      <div class="sa-modal-content" style="max-width:450px;">
        <div class="sa-modal-header">
          <h2 id="deleteUserModalTitle"><span class="material-symbols-outlined">person_remove</span> Delete User</h2>
          <button type="button" class="sa-modal-close-btn" onclick="closeDeleteUserModal()" aria-label="Close">&times;</button>
        </div>
        <div class="sa-modal-body" style="text-align:center;">
          <p style="margin:0 0 4px;">Are you sure you want to move</p>
          <p style="margin:0;font-weight:600;font-size:1.05rem;" id="deleteUserName"></p>
          <p style="margin:8px 0 0;color:#6b7280;font-size:.9rem;">to the trash? You can restore them later.</p>
        </div>
        <div class="sa-modal-footer">
          <button type="button" class="sa-btn sa-btn-danger" onclick="confirmDeleteUser()">
            <i class="bi bi-trash-fill me-1"></i> Move to Trash
          </button>
          <button type="button" class="sa-btn sa-btn-outline cancel-btn" onclick="closeDeleteUserModal()">Cancel</button>
        </div>
      </div>
    </div>

    <div id="borrowModal" class="modal" style="display:none;">
      <div class="modal-content" style="max-width:900px;max-height:90vh;overflow-y:auto;">
        <span class="close" onclick="closeBorrowModal()">&times;</span>
        <h2>Borrow Book</h2>
        <div class="borrow-student-info">
          <p><strong>Student:</strong> <span id="borrowStudentName"></span></p>
          <p><strong>Student ID:</strong> <span id="borrowStudentId"></span></p>
        </div>
        <div id="borrowStep1" class="borrow-step">
          <h3>Step 1: Select a Book</h3>
          <div class="book-search-section"><input type="text" id="borrowBookSearch" class="form-control" placeholder="Search by title, author, ISBN..."></div>
          <div id="borrowBooksList" class="books-list" style="max-height:400px;overflow-y:auto;margin-top:15px;"><p class="loading-text">Loading books...</p></div>
        </div>
        <div id="borrowStep2" class="borrow-step" style="display:none;">
          <h3>Step 2: Select a Copy</h3>
          <div class="selected-book-info">
            <p><strong>Book:</strong> <span id="selectedBookTitle"></span></p>
            <p><strong>Author:</strong> <span id="selectedBookAuthor"></span></p>
          </div>
          <div id="borrowCopiesList" class="copies-list"><p class="loading-text">Loading copies...</p></div>
          <button class="btn-secondary" onclick="backToBookSelection()">&#8592; Back to Book Selection</button>
        </div>
        <div id="borrowStep3" class="borrow-step" style="display:none;">
          <h3>Step 3: Confirm Borrowing</h3>
          <div class="borrow-summary">
            <p><strong>Student:</strong> <span id="confirmStudentName"></span></p>
            <p><strong>Book:</strong> <span id="confirmBookTitle"></span></p>
            <p><strong>Accession #:</strong> <span id="confirmAccessionNumber"></span></p>
            <p><strong>Condition:</strong> <span id="confirmCondition"></span></p>
          </div>
          <div class="form-group"><label for="borrowDueDate">Due Date:</label><input type="date" id="borrowDueDate" class="form-control" required></div>
          <div class="form-actions">
            <button class="btn-secondary" onclick="backToCopySelection()">&#8592; Back</button>
            <button class="btn-primary" onclick="confirmBorrowing()">Confirm Borrow</button>
          </div>
        </div>
      </div>
    </div>

    <div id="bulkBorrowModal" class="modal" style="display:none;">
      <div class="modal-content" style="max-width:1000px;max-height:90vh;overflow-y:auto;">
        <span class="close" onclick="closeBulkBorrowModal()">&times;</span>
        <h2>&#128218; Borrow Books</h2>
        <div class="borrow-student-info">
          <p><strong>Student:</strong> <span id="bulkBorrowStudentName"></span></p>
          <p><strong>Student ID:</strong> <span id="bulkBorrowStudentId"></span></p>
        </div>
        <div id="bulkBorrowInstructions"></div>
        <div class="bulk-borrow-container">
          <div class="selected-books-cart">
            <h3>&#128214; Cart (<span id="selectedBooksCount">0</span>)</h3>
            <div id="selectedBooksCart" class="cart-items"><p class="empty-cart">Click books below to add them here</p></div>
            <div class="form-group" style="margin-top:20px;"><label for="bulkBorrowDueDate">&#128197; Return Date:</label><input type="date" id="bulkBorrowDueDate" class="form-control" required></div>
            <button class="btn-primary" onclick="confirmBulkBorrowing()" style="width:100%;margin-top:15px;font-size:16px;padding:12px;"><span class="material-symbols-outlined">check_circle</span>Confirm Borrow (<span id="confirmBooksCount">0</span> books)</button>
          </div>
          <div class="available-books-section">
            <h3>&#128218; Available Books</h3>
            <input type="text" id="bulkBookSearch" class="form-control" placeholder="&#128269; Search by title or author..." style="margin-bottom:15px;">
            <div id="bulkBooksList" class="books-list" style="max-height:500px;overflow-y:auto;"><p class="loading-text">Loading books...</p></div>
          </div>
        </div>
      </div>
    </div>
  `
}) %>
