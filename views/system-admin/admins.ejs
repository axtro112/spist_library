<%
  var extraHead = '<link rel="stylesheet" href="/css/super-admin/admins-modal.css" /><script src="/js/admin/users.js" defer><\/script><script src="/js/admin-management.js" defer><\/script>';
%>
<%- include('../partials/system-admin-layout', {
  title: 'Admin Management - SPIST Library (Super Admin)',
  adminEmail: adminEmail,
  adminId: adminId,
  adminRole: adminRole,
  activePage: 'admins',
  extraHead: extraHead,
  body: `
    <div class="section-header d-flex align-items-center justify-content-between flex-wrap gap-3">
      <div>
        <h2><i class="bi bi-shield-person me-2"></i>Admin Management</h2>
      </div>
      <button id="addAdminBtn" class="sa-btn sa-btn-success" style="display:none;">
        <i class="bi bi-person-plus-fill me-1"></i>Add Admin
      </button>
    </div>

    <div class="section-card">
      <div class="sa-filter-bar mb-3">
        <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">
          <input type="checkbox" id="selectAllAdmins" style="width:18px;height:18px;cursor:pointer;" title="Select all" />
          <span id="adminsSelectedCount" style="white-space:nowrap;font-size:13px;color:#6b7280;"></span>
        </div>
        <button id="bulkDeleteAdminsBtn" class="sa-btn sa-btn-danger" disabled style="white-space:nowrap;">
          <i class="bi bi-trash-fill me-1"></i>Delete Selected
        </button>
      </div>

      <div class="sa-table-wrapper">
        <table class="user-table">
          <thead>
            <tr>
              <th style="width:40px;"></th>
              <th>ID</th>
              <th>Name</th>
              <th>Role</th>
              <th>Email</th>
              <th>Created At</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td colspan="7" style="text-align:center;padding:40px;">Loading admins...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Toast Notification -->
    <div id="toastNotification"></div>

    <!-- Add Admin Modal -->
    <div id="modalAddAdmin" class="modal sa-modal" role="dialog" aria-modal="true" aria-labelledby="addAdminModalTitle">
      <div class="sa-modal-content">
        <div class="sa-modal-header">
          <h2 id="addAdminModalTitle"><i class="bi bi-person-plus-fill"></i> Add Admin</h2>
          <button type="button" class="sa-modal-close-btn"
                  onclick="document.getElementById('modalAddAdmin').classList.remove('show')"
                  aria-label="Close dialog">&times;</button>
        </div>
        <form id="addAdminForm" novalidate>
          <div class="sa-modal-body">
            <div id="addAdminError" class="sa-modal-error" role="alert"></div>
            <div class="sa-form-group">
              <label for="addName">Full Name <span class="req">*</span></label>
              <input type="text" id="addName" name="fullname" required
                     autocomplete="name" placeholder="Enter full name"
                     maxlength="80" />
            </div>
            <div class="sa-form-group">
              <label for="addEmail">Email Address <span class="req">*</span></label>
              <input type="email" id="addEmail" name="email" required
                     autocomplete="email" placeholder="Enter email address" />
            </div>
            <div class="sa-form-group">
              <label for="addPassword">Password <span class="req">*</span></label>
              <div class="sa-password-wrap">
                <input type="password" id="addPassword" name="password" required
                       autocomplete="new-password" placeholder="Minimum 8 characters"
                       maxlength="72" />
                <button type="button" class="sa-eye-toggle" id="toggleAddPassword"
                        tabindex="-1" aria-label="Toggle password visibility">
                  <span class="material-symbols-outlined" id="eyeIconPassword">visibility</span>
                </button>
              </div>
            </div>
            <div class="sa-form-group">
              <label for="addConfirmPassword">Confirm Password <span class="req">*</span></label>
              <div class="sa-password-wrap">
                <input type="password" id="addConfirmPassword" name="confirmPassword" required
                       autocomplete="new-password" placeholder="Re-enter your password"
                       maxlength="72" />
                <button type="button" class="sa-eye-toggle" id="toggleAddConfirmPassword"
                        tabindex="-1" aria-label="Toggle confirm password visibility">
                  <span class="material-symbols-outlined" id="eyeIconConfirm">visibility</span>
                </button>
              </div>
            </div>
            <div class="sa-form-group">
              <label for="addRole">Role <span class="req">*</span></label>
              <select id="addRole" name="role" required>
                <option value="system_admin">System Admin</option>
                <option value="super_admin">Super Admin</option>
              </select>
            </div>
          </div>
          <div class="sa-modal-footer">
            <button type="submit" id="addAdminSubmitBtn" class="sa-btn sa-btn-success">
              <i class="bi bi-check-circle me-1"></i> Create Admin
            </button>
            <button type="button" class="sa-btn sa-btn-outline cancel-btn" id="addAdminCancelBtn">Cancel</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Edit Admin Modal -->
    <div id="modalEdit" class="modal sa-modal" role="dialog" aria-modal="true" aria-labelledby="editAdminModalTitle">
      <div class="sa-modal-content">
        <div class="sa-modal-header">
          <h2 id="editAdminModalTitle"><span class="material-symbols-outlined">manage_accounts</span> Edit Admin</h2>
          <button type="button" class="sa-modal-close-btn" onclick="adminManager.closeEditModal()" aria-label="Close">&times;</button>
        </div>
        <form id="editAdminForm" novalidate>
          <div class="sa-modal-body">
            <div id="editAdminError" class="sa-modal-error" role="alert"></div>
            <div class="sa-form-group">
              <label for="editName">Full Name <span class="req">*</span></label>
              <input type="text" id="editName" name="fullname" required autocomplete="name" placeholder="Enter full name" maxlength="80" />
            </div>
            <div class="sa-form-group">
              <label for="editEmail">Email Address <span class="req">*</span></label>
              <input type="email" id="editEmail" name="email" required autocomplete="email" placeholder="Enter email address" />
            </div>
            <div class="sa-form-group">
              <label for="editRole">Role <span class="req">*</span></label>
              <select id="editRole" name="role" required>
                <option value="system_admin">System Admin</option>
                <option value="super_admin">Super Admin</option>
              </select>
            </div>
            <div class="sa-form-group">
              <label for="editPassword">New Password <span style="font-weight:400;color:#9ca3af;font-size:.8rem;">(leave blank to keep current)</span></label>
              <div class="sa-password-wrap">
                <input type="password" id="editPassword" name="password" placeholder="Enter new password" autocomplete="new-password" maxlength="72" />
                <button type="button" class="sa-eye-toggle" onclick="togglePasswordVisibility('editPassword', this)" tabindex="-1" aria-label="Toggle password visibility">
                  <span class="material-symbols-outlined">visibility</span>
                </button>
              </div>
            </div>
            <div class="sa-form-group" id="editConfirmPasswordGroup" style="display:none;">
              <label for="editConfirmPassword">Confirm New Password <span class="req">*</span></label>
              <div class="sa-password-wrap">
                <input type="password" id="editConfirmPassword" placeholder="Re-enter new password" autocomplete="new-password" maxlength="72" />
                <button type="button" class="sa-eye-toggle" onclick="togglePasswordVisibility('editConfirmPassword', this)" tabindex="-1" aria-label="Toggle confirm password visibility">
                  <span class="material-symbols-outlined">visibility</span>
                </button>
              </div>
            </div>
          </div>
          <div class="sa-modal-footer">
            <button type="submit" class="sa-btn sa-btn-success">Save Changes</button>
            <button type="button" class="sa-btn sa-btn-outline cancel-btn">Cancel</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div id="modalDelete" class="modal">
      <div class="modal-content">
        <h2>Confirm Deletion</h2>
        <p>Are you sure you want to delete this admin?</p>
        <div class="form-actions">
          <button class="delete-confirm-btn">Delete Admin</button>
          <button class="cancel-btn">Cancel</button>
        </div>
      </div>
    </div>
  `
}) %>
