<%
  var extraHead = '<link rel="stylesheet" href="/css/super-admin/borrowed.css?v=20260327a"><script src="/js/vendor/html5-qrcode.min.js"><\/script><script src="https://cdn.jsdelivr.net/npm/html5-qrcode@2.3.8/minified/html5-qrcode.min.js"><\/script><script src="/js/admin/borrowed.js?v=20260327a" defer><\/script><script src="/js/borrowed-books.js?v=20260327d" defer><\/script>';
%>
<%- include('../partials/system-admin-layout', {
  title: 'Borrowed Books Management - Southern Philippines Institute of Science & Technology',
  adminEmail: adminEmail,
  adminId: adminId,
  adminRole: adminRole,
  activePage: 'borrowed-books',
  extraHead: extraHead,
  body: `
    <div class="section-header">
      <div>
        <h1>Borrowed Books Management</h1>
      </div>
    </div>

    <div class="section-card">
      <div class="sa-filter-bar">
        <div class="sa-search-wrap">
          <i class="bi bi-search"></i>
          <input
            id="searchInput"
            type="text"
            class="form-control"
            placeholder="Search by student name, ID, book title, accession number..."
          />
        </div>
        <select id="categoryFilter" class="sa-filter-select">
          <option value="">All Categories</option>
        </select>
        <select id="statusFilter" class="sa-filter-select">
          <option value="">All Status</option>
          <option value="pending_pickup">Pending Pickup</option>
          <option value="claim_expired">Claim Expired</option>
          <option value="picked_up">Picked Up</option>
          <option value="overdue">Overdue</option>
          <option value="returned">Returned</option>
        </select>
        <button id="clearFilters" class="sa-clear-btn" title="Clear all filters">
          <i class="bi bi-funnel-fill"></i> Clear
        </button>
      </div>

      <div class="d-flex align-items-center mb-2">
        <span id="resultCount" class="result-count"></span>
      </div>

          <!-- Lifecycle Status Tabs -->
    <div class="borrow-lifecycle-panel">
      <div class="borrow-tabs">
        <button class="borrow-tab active" data-status="pending_pickup">
          <i class="bi bi-box-seam"></i>
          <span>Pending Pickup</span>
          <span class="tab-badge" id="count-pending-pickup">0</span>
        </button>
        <button class="borrow-tab" data-status="pending_return">
          <i class="bi bi-arrow-return-left"></i>
          <span>Pending Return</span>
          <span class="tab-badge" id="count-pending-return">0</span>
        </button>
        <button class="borrow-tab" data-status="returned">
          <i class="bi bi-clock-history"></i>
          <span>History</span>
          <span class="tab-badge" id="count-returned">0</span>
        </button>
      </div>
    </div>

      <div class="sa-table-wrapper">
        <table class="borrowings-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Student</th>
              <th>Book</th>
              <th>Accession No</th>
              <th>Borrow Date</th>
              <th>Due Date</th>
              <th>Picked Up</th>
              <th>Returned</th>
              <th>Status</th>
              <th>Category</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td colspan="11" style="text-align: center; padding: 40px;">
                <i class="bi bi-hourglass-split" style="font-size: 48px; color: #9ca3af;"></i>
                <p style="margin-top: 10px; color: #6b7280;">Loading borrowing records...</p>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Scanner Confirmation Modal (shared pickup/return flow) -->
    <div id="borrowScannerModal" class="modal sa-modal" role="dialog" aria-modal="true" aria-labelledby="borrowScannerTitle">
      <div class="sa-modal-dialog sa-modal-xl scanner-modal-dialog">
      <div class="sa-modal-content scanner-modal-content">
        <div class="sa-modal-header scanner-modal-header">
          <h2 id="borrowScannerTitle">Scan to Confirm</h2>
          <button type="button" id="borrowScannerCloseBtn" class="sa-modal-close scanner-close-btn" onclick="closeModal()" aria-label="Close scanner modal">&times;</button>
        </div>
        <div class="sa-modal-body scanner-modal-body scanner-modal-body-collapsed" id="borrowScannerBody">
          <div class="scanner-camera-panel">
            <div class="scanner-reader-shell">
              <div id="borrowQrReader"></div>
              <div class="scanner-scan-frame" aria-hidden="true"></div>
              <div id="borrowScanPlaceholder" class="scanner-placeholder">Camera preview will appear here</div>
            </div>
            <p id="borrowScannerStatusText" class="scanner-status-text">Ready to scan. Click Start Camera to begin.</p>
            <div class="scanner-controls">
              <button id="borrowScanStartBtn" type="button" class="sa-btn sa-btn-primary">Start Camera</button>
              <button id="borrowScanStopBtn" type="button" class="sa-btn sa-hidden">Stop Camera</button>
            </div>
          </div>
          <div class="scanner-result-panel scanner-result-panel-collapsed" id="borrowScanResultPanel">
            <div class="scanner-result-empty" id="borrowScanEmpty">No scanned result yet</div>
            <div class="scanner-result-grid sa-hidden" id="borrowScanResultGrid">
              <div><span class="scanner-label">Accession Number:</span> <span id="borrowScanAccession">—</span></div>
              <div><span class="scanner-label">Book Title:</span> <span id="borrowScanBookTitle">—</span></div>
              <div><span class="scanner-label">Author:</span> <span id="borrowScanBookAuthor">—</span></div>
              <div><span class="scanner-label">Student/Borrower:</span> <span id="borrowScanStudentName">—</span></div>
              <div><span class="scanner-label">Status:</span> <span id="borrowScanBorrowStatus">—</span></div>
              <div><span class="scanner-label">Pickup Date:</span> <span id="borrowScanPickupDate">—</span></div>
              <div><span class="scanner-label">Due Date:</span> <span id="borrowScanDueDate">—</span></div>
              <div><span class="scanner-label">Due State:</span> <span id="borrowScanDueState">—</span></div>
            </div>
            <div id="borrowScanMessage" class="scanner-message sa-hidden"></div>
            <div id="borrowScanHistory" class="scanner-history" style="display:none;">
              <div class="scanner-history-title-row">Recent Borrowing History</div>
              <div id="borrowScanHistoryEmpty" class="scanner-history-empty" style="display:none;"></div>
              <ul id="borrowScanHistoryList" class="scanner-history-list" style="display:none;"></ul>
            </div>
          </div>
        </div>
        <div class="sa-modal-footer scanner-modal-footer scanner-modal-footer-collapsed" id="borrowScannerFooter">
          <button type="button" id="borrowScanActionBtn" class="sa-btn sa-btn-success" disabled>No Action</button>
          <button type="button" id="borrowScanResetBtn" class="sa-btn sa-btn-outline">Reset</button>
        </div>
      </div>
      </div>
    </div>

    <!-- Pickup Confirmation Modal -->
    <div id="pickupModal" class="modal sa-modal">
      <div class="sa-modal-dialog sa-modal-lg">
      <div class="sa-modal-content">
        <div class="sa-modal-header">
          <h2>Confirm Book Pickup</h2>
          <button type="button" class="sa-modal-close sa-modal-close-btn" onclick="closeModal()">&times;</button>
        </div>
        <div class="sa-modal-body"><!-- Content will be dynamically inserted --></div>
        <div class="sa-modal-footer sa-modal-actions-stack">
          <button class="btn btn-secondary" onclick="closeModal()">Cancel</button>
          <button class="btn btn-success btn-confirm-pickup">Confirm Pickup</button>
        </div>
      </div>
      </div>
    </div>

    <!-- Return Confirmation Modal -->
    <div id="returnModal" class="modal sa-modal">
      <div class="sa-modal-dialog sa-modal-lg">
      <div class="sa-modal-content">
        <div class="sa-modal-header">
          <h2>Confirm Book Return</h2>
          <button type="button" class="sa-modal-close sa-modal-close-btn" onclick="closeModal()">&times;</button>
        </div>
        <div class="sa-modal-body"><!-- Content will be dynamically inserted --></div>
        <div class="sa-modal-footer sa-modal-actions-stack">
          <button class="btn btn-secondary" onclick="closeModal()">Cancel</button>
          <button class="btn btn-primary btn-confirm-return">Confirm Return</button>
        </div>
      </div>
      </div>
    </div>

    <!-- Details Modal -->
    <div id="detailsModal" class="modal sa-modal">
      <div class="sa-modal-dialog sa-modal-lg sa-detail-modal">
      <div class="sa-modal-content">
        <div class="sa-modal-header">
          <h2>Borrowing Details</h2>
          <button type="button" class="sa-modal-close sa-modal-close-btn" onclick="closeModal()">&times;</button>
        </div>
        <div class="sa-modal-body borrow-details-body"><!-- Content will be dynamically inserted --></div>
        <div class="sa-modal-footer sa-modal-actions-stack">
          <button class="btn btn-secondary" onclick="closeModal()">Close</button>
        </div>
      </div>
      </div>
    </div>
  `
}) %>


