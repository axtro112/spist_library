<%
  var extraHead = '<script src="/js/admin/borrowed.js" defer><\/script><script src="/js/borrowed-books.js" defer><\/script>';
%>
<%- include('../partials/system-admin-layout', {
  title: 'Borrowed Books Management - SPIST Library',
  adminEmail: adminEmail,
  adminId: adminId,
  adminRole: adminRole,
  activePage: 'borrowed-books',
  extraHead: extraHead,
  body: `
    <div class="section-header">
      <div>
        <h1>Borrowed Books Management</h1>
      </div>
    </div>

    <div class="section-card">
      <div class="sa-filter-bar">
        <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">
          <input type="checkbox" id="selectAllBorrowings" style="width:18px;height:18px;cursor:pointer;" title="Select all">
          <span id="borrowingsSelectedCount" style="white-space:nowrap;font-size:13px;color:#6b7280;"></span>
        </div>
        <div class="sa-search-wrap">
          <i class="bi bi-search"></i>
          <input
            id="searchInput"
            type="text"
            class="form-control"
            placeholder="Search by student name, ID, book title, accession number..."
          />
        </div>
        <select id="categoryFilter" class="sa-filter-select">
          <option value="">All Categories</option>
        </select>
        <select id="statusFilter" class="sa-filter-select">
          <option value="">All Status</option>
          <option value="pending_pickup">Pending Pickup</option>
          <option value="claim_expired">Claim Expired</option>
          <option value="picked_up">Picked Up</option>
          <option value="overdue">Overdue</option>
          <option value="returned">Returned</option>
        </select>
        <button id="bulkConfirmPickupBtn" class="sa-btn sa-btn-success" disabled style="white-space:nowrap;">
          <i class="bi bi-check-circle me-1"></i>Confirm Pickup
        </button>
        <button id="bulkConfirmReturnBtn" class="sa-btn sa-btn-primary" disabled style="white-space:nowrap;">
          <i class="bi bi-arrow-return-left me-1"></i>Confirm Return
        </button>
        <button id="clearFilters" class="sa-clear-btn" title="Clear all filters">
          <i class="bi bi-funnel-fill"></i> Clear
        </button>
      </div>

      <div class="d-flex align-items-center mb-2">
        <span id="resultCount" class="result-count"></span>
      </div>

          <!-- Lifecycle Status Tabs -->
    <div class="borrow-lifecycle-panel">
      <div class="borrow-tabs">
        <button class="borrow-tab active" data-status="pending_pickup">
          <i class="bi bi-box-seam"></i>
          <span>Pending Pickup</span>
          <span class="tab-badge" id="count-pending-pickup">0</span>
        </button>
        <button class="borrow-tab" data-status="pending_return">
          <i class="bi bi-arrow-return-left"></i>
          <span>Pending Return</span>
          <span class="tab-badge" id="count-pending-return">0</span>
        </button>
        <button class="borrow-tab" data-status="returned">
          <i class="bi bi-clock-history"></i>
          <span>History</span>
          <span class="tab-badge" id="count-returned">0</span>
        </button>
      </div>
    </div>

      <div class="sa-table-wrapper">
        <table class="borrowings-table">
          <thead>
            <tr>
              <th style="width:40px;"></th>
              <th>ID</th>
              <th>Student</th>
              <th>Book</th>
              <th>Accession No</th>
              <th>Borrow Date</th>
              <th>Due Date</th>
              <th>Picked Up</th>
              <th>Returned</th>
              <th>Status</th>
              <th>Category</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td colspan="12" style="text-align: center; padding: 40px;">
                <i class="bi bi-hourglass-split" style="font-size: 48px; color: #9ca3af;"></i>
                <p style="margin-top: 10px; color: #6b7280;">Loading borrowing records...</p>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Pickup Confirmation Modal -->
    <div id="pickupModal" class="modal">
      <div class="modal-content">
        <div class="modal-header">
          <h2>Confirm Book Pickup</h2>
          <button onclick="closeModal()" style="background: none; border: none; font-size: 24px; cursor: pointer;">&times;</button>
        </div>
        <div class="modal-body"><!-- Content will be dynamically inserted --></div>
        <div class="modal-footer">
          <button class="btn btn-secondary" onclick="closeModal()">Cancel</button>
          <button class="btn btn-success btn-confirm-pickup">Confirm Pickup</button>
        </div>
      </div>
    </div>

    <!-- Return Confirmation Modal -->
    <div id="returnModal" class="modal">
      <div class="modal-content">
        <div class="modal-header">
          <h2>Confirm Book Return</h2>
          <button onclick="closeModal()" style="background: none; border: none; font-size: 24px; cursor: pointer;">&times;</button>
        </div>
        <div class="modal-body"><!-- Content will be dynamically inserted --></div>
        <div class="modal-footer">
          <button class="btn btn-secondary" onclick="closeModal()">Cancel</button>
          <button class="btn btn-primary btn-confirm-return">Confirm Return</button>
        </div>
      </div>
    </div>

    <!-- Details Modal -->
    <div id="detailsModal" class="modal">
      <div class="modal-content">
        <div class="modal-header">
          <h2>Borrowing Details</h2>
          <button onclick="closeModal()" style="background: none; border: none; font-size: 24px; cursor: pointer;">&times;</button>
        </div>
        <div class="modal-body"><!-- Content will be dynamically inserted --></div>
        <div class="modal-footer">
          <button class="btn btn-secondary" onclick="closeModal()">Close</button>
        </div>
      </div>
    </div>
  `
}) %>

