<%
  var extraHead = [
    '<link rel="stylesheet" href="/css/admin/trash.css?v=20260327c">',
    '<script src="/js/admin/trash-bootstrap.js?v=20260327c" defer><\/script>',
    '<script src="/js/shared/utils/safeFetch.js?v=20260327c" defer><\/script>',
    '<script src="/js/admin/trash/services.js?v=20260327c" defer><\/script>',
    '<script src="/js/admin/trash/table.js?v=20260327c" defer><\/script>',
    '<script src="/js/admin/trash/actions.js?v=20260327c" defer><\/script>',
    '<script src="/js/admin/trash/filters.js?v=20260327c" defer><\/script>',
    '<script src="/js/admin/trash/index.js?v=20260327c" defer><\/script>',
  ].join('');
%>
<%- include('../partials/system-admin-layout', {
  title: 'Trash Manager - Southern Philippines Institute of Science & Technology',
  adminEmail: adminEmail,
  adminId: adminId,
  adminRole: adminRole,
  activePage: 'trash-bin',
  extraHead: extraHead,
  body: `
    <div class="section-header">
      <h2><i class="bi bi-trash2 me-2"></i>Trash Bin</h2>
    </div>

    <div class="section-card">
      <!-- -- Filter Bar -- -->
      <div class="sa-filter-bar">
        <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">
          <input type="checkbox" id="trashMasterCb" title="Select all on this page">
        </div>

        <div class="sa-search-wrap">
          <i class="bi bi-search"></i>
          <input type="text" id="trashSearch" placeholder="Search...">
        </div>

        <select id="trashTabFilter" class="sa-filter-select" style="min-width:150px;"></select>

        <button id="trashBulkRestoreBtn" class="sa-btn sa-btn-success" disabled>
          <i class="bi bi-arrow-counterclockwise me-1"></i>Restore
        </button>
        <button id="trashBulkDeleteBtn" class="sa-btn sa-btn-danger" disabled>
          <i class="bi bi-trash3-fill me-1"></i>Delete
        </button>
        <button id="trashClearBtn" class="sa-clear-btn">
          <i class="bi bi-x-circle me-1"></i>Clear
        </button>
      </div>

      <!-- -- Tabs -- -->
      <div class="trash-tabs">
        <button class="trash-tab active" data-entity="books">
          <i class="bi bi-book"></i>Books
        </button>
        <button class="trash-tab" data-entity="users">
          <i class="bi bi-people"></i>Users
        </button>
        <button class="trash-tab" data-entity="admins">
          <i class="bi bi-person-badge"></i>Admins
        </button>
      </div>

      <!-- -- Table -- -->
      <div class="sa-table-wrapper" id="trashTableWrap">
        <table class="user-table">
          <tbody>
            <tr>
              <td colspan="10" style="text-align:center;padding:40px;color:#6b7280;">
                <div class="trash-spinner"></div>Loading...
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div id="trashRestoreModal" class="trash-modal" role="dialog" aria-modal="true" aria-labelledby="trashRestoreTitle">
      <div class="trash-modal-content">
        <div class="trash-modal-header trash-modal-header--restore">
          <h2 id="trashRestoreTitle"><i class="bi bi-arrow-counterclockwise"></i> Restore Items</h2>
          <button type="button" class="trash-modal-close" id="trashRestoreClose" aria-label="Close">&times;</button>
        </div>
        <div class="trash-modal-body">
          <div class="trash-modal-info">
            <i class="bi bi-info-circle-fill"></i>
            <p id="trashRestoreMessage">Restore selected items?</p>
          </div>
        </div>
        <div class="trash-modal-footer">
          <button type="button" id="trashRestoreConfirmBtn" class="sa-btn sa-btn-success">
            <i class="bi bi-arrow-counterclockwise me-1"></i> Restore
          </button>
          <button type="button" id="trashRestoreCancelBtn" class="sa-btn sa-btn-outline cancel-btn">Cancel</button>
        </div>
      </div>
    </div>

    <div id="trashDeleteConfirmModal" class="trash-modal" role="dialog" aria-modal="true" aria-labelledby="trashDeleteConfirmTitle">
      <div class="trash-modal-content">
        <div class="trash-modal-header trash-modal-header--danger">
          <h2 id="trashDeleteConfirmTitle"><i class="bi bi-exclamation-triangle-fill"></i> Permanent Delete</h2>
          <button type="button" class="trash-modal-close" id="trashDeleteClose" aria-label="Close">&times;</button>
        </div>
        <div class="trash-modal-body">
          <div class="trash-modal-info trash-modal-info--danger">
            <i class="bi bi-exclamation-octagon-fill"></i>
            <p id="trashDeleteConfirmMessage">Permanently delete selected items?</p>
          </div>
        </div>
        <div class="trash-modal-footer">
          <button type="button" id="trashDeleteConfirmBtn" class="sa-btn sa-btn-danger">
            <i class="bi bi-trash3-fill me-1"></i> Delete Forever
          </button>
          <button type="button" id="trashDeleteCancelBtn" class="sa-btn sa-btn-outline cancel-btn">Cancel</button>
        </div>
      </div>
    </div>

    <div id="trashDeleteTypeModal" class="trash-modal" role="dialog" aria-modal="true" aria-labelledby="trashDeleteTypeTitle">
      <div class="trash-modal-content">
        <div class="trash-modal-header trash-modal-header--danger">
          <h2 id="trashDeleteTypeTitle"><i class="bi bi-shield-exclamation"></i> Confirm Deletion</h2>
          <button type="button" class="trash-modal-close" id="trashDeleteTypeClose" aria-label="Close">&times;</button>
        </div>
        <div class="trash-modal-body">
          <div class="trash-modal-info trash-modal-info--danger">
            <i class="bi bi-keyboard-fill"></i>
            <p>Type <strong>DELETE</strong> to continue.</p>
          </div>
          <div class="trash-delete-input-wrap">
            <input id="trashDeleteTypeInput" type="text" class="sa-filter-select" placeholder="Type DELETE" autocomplete="off" />
          </div>
        </div>
        <div class="trash-modal-footer">
          <button type="button" id="trashDeleteTypeConfirmBtn" class="sa-btn sa-btn-danger" disabled>
            <i class="bi bi-check2-circle me-1"></i> Confirm
          </button>
          <button type="button" id="trashDeleteTypeCancelBtn" class="sa-btn sa-btn-outline cancel-btn">Cancel</button>
        </div>
      </div>
    </div>
  `
}) %>


