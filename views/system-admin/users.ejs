<%
  var extraHead = '<link rel="stylesheet" href="/css/super-admin/admins-modal.css"><link rel="stylesheet" href="/css/system-admin/users-interface.css?v=20260327b"><script src="/js/system-admin/users-utils-adapter.js" defer><\/script><script src="/js/super-admin/users.js" defer><\/script><script src="/js/admin/users.js" defer><\/script><script src="/js/notification-user-modal.js" defer><\/script><script src="/js/user-violations-modal.js" defer><\/script><script src="/js/admin.js" defer><\/script><script src="/js/user.js" defer><\/script>';
%>
<%- include('../partials/system-admin-layout', {
  title: 'User Management - Southern Philippines Institute of Science & Technology',
  adminEmail: adminEmail,
  adminId: adminId,
  adminRole: adminRole,
  activePage: 'users',
  extraHead: extraHead,
  body: `
    <!-- Legacy inline users script removed during frontend architecture cleanup. -->

    <div class="section-header d-flex align-items-center justify-content-between flex-wrap gap-3">
      <div>
        <h2><i class="bi bi-people me-2"></i>User Management</h2>
      </div>
    </div>

    <div class="section-card users-interface-card">
    <div class="sa-filter-bar mb-3">
        <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">
          <input type="checkbox" id="selectAllUsers" style="width:18px;height:18px;cursor:pointer;" title="Select all" />
          <span id="selectedCount" class="small fw-medium text-secondary" style="white-space:nowrap;"></span>
        </div>
        <div class="sa-search-wrap" style="flex:1;min-width:200px;">
          <i class="bi bi-search"></i>
          <input type="text" id="usersSearchInput" class="sa-filter-select" placeholder="Search by name, ID, email, stage, or program..." />
        </div>
        <select id="usersStageFilter" class="sa-filter-select">
          <option value="All">All Stages</option>
          <option value="Pre-School">Pre-School</option>
          <option value="Prep">Prep</option>
          <option value="Kinder">Kinder</option>
          <option value="Elementary">Elementary</option>
          <option value="Junior High">Junior High</option>
          <option value="Senior High">Senior High</option>
          <option value="College">College</option>
        </select>
        <select id="usersCourseFilter" class="sa-filter-select">
          <option value="All">All Programs / Courses</option>
          <option value="BS Computer Engineering">BS Computer Engineering</option>
          <option value="BS Computer Science">BS Computer Science</option>
          <option value="BS Information Technology">BS Information Technology</option>
          <option value="BS Tourism Management">BS Tourism Management</option>
          <option value="BS Business Administration - Major in Marketing Management">BS Business Administration - Major in Marketing Management</option>
          <option value="BS Business Administration - Major in Operations Management">BS Business Administration - Major in Operations Management</option>
          <option value="BS Accountancy">BS Accountancy</option>
          <option value="BS Hospitality Management">BS Hospitality Management</option>
          <option value="Bachelor in Elementary Education">Bachelor in Elementary Education</option>
          <option value="Bachelor in Secondary Education - Major in English">Bachelor in Secondary Education - Major in English</option>
          <option value="Bachelor in Secondary Education - Major in Mathematics">Bachelor in Secondary Education - Major in Mathematics</option>
          <option value="Bachelor in Secondary Education - Major in Filipino">Bachelor in Secondary Education - Major in Filipino</option>
          <option value="Bachelor in Secondary Education - Major in Social Studies">Bachelor in Secondary Education - Major in Social Studies</option>
          <option value="Bachelor in Secondary Education - Major in Science">Bachelor in Secondary Education - Major in Science</option>
        </select>
        <select id="usersYearFilter" class="sa-filter-select">
          <option value="All">All Year Levels</option>
        </select>
        <select id="usersStatusFilter" class="sa-filter-select">
          <option value="All">All Status</option>
          <option value="active">Active</option>
          <option value="inactive">Inactive</option>
        </select>

        <button id="bulkEditUsersBtn" class="sa-btn sa-btn-primary" title="Edit selected users" disabled>
          <i class="bi bi-pencil-fill me-1"></i>Edit
        </button>
        <button id="bulkDeleteBtn" class="sa-btn sa-btn-danger" title="Delete selected users" disabled>
          <i class="bi bi-trash-fill me-1"></i>Delete
        </button>
        <button id="usersClearFilters" class="sa-clear-btn">
          <i class="bi bi-funnel-fill"></i> Clear
        </button>
      </div>

      <div id="usersResultCount" class="text-end text-muted small mb-2">Showing 0 of 0 users</div>

      <div class="sa-table-wrapper">
        <table class="user-table users-interface-table w-100">
          <thead>
            <tr>
              <th style="width:40px;"></th>
              <th>Name</th>
              <th>Student ID</th>
              <th>Stage</th>
              <th>Program / Course</th>
              <th>Year Level</th>
              <th>Rented Books</th>
              <th>Books Title</th>
              <th>Date to Return</th>
              <th style="width:120px;">Actions</th>
            </tr>
          </thead>
          <tbody><tr><td>Loading students data...</td></tr></tbody>
        </table>
      </div>
    </div>

    <div id="borrowModal" class="modal" style="display:none;">
      <div class="modal-content" style="max-width:900px;max-height:90vh;overflow-y:auto;">
        <span class="close" onclick="closeBorrowModal()">&times;</span>
        <h2>Borrow Book</h2>
        <div class="borrow-student-info">
          <p><strong>Student:</strong> <span id="borrowStudentName"></span></p>
          <p><strong>Student ID:</strong> <span id="borrowStudentId"></span></p>
        </div>
        <div id="borrowStep1" class="borrow-step">
          <h3>Step 1: Select a Book</h3>
          <div class="book-search-section"><input type="text" id="borrowBookSearch" class="form-control" placeholder="Search by title, author, ISBN..."></div>
          <div id="borrowBooksList" class="books-list" style="max-height:400px;overflow-y:auto;margin-top:15px;"><p class="loading-text">Loading books...</p></div>
        </div>
        <div id="borrowStep2" class="borrow-step" style="display:none;">
          <h3>Step 2: Select a Copy</h3>
          <div class="selected-book-info">
            <p><strong>Book:</strong> <span id="selectedBookTitle"></span></p>
            <p><strong>Author:</strong> <span id="selectedBookAuthor"></span></p>
          </div>
          <div id="borrowCopiesList" class="copies-list"><p class="loading-text">Loading copies...</p></div>
          <button class="btn-secondary" onclick="backToBookSelection()">&#8592; Back to Book Selection</button>
        </div>
        <div id="borrowStep3" class="borrow-step" style="display:none;">
          <h3>Step 3: Confirm Borrowing</h3>
          <div class="borrow-summary">
            <p><strong>Student:</strong> <span id="confirmStudentName"></span></p>
            <p><strong>Book:</strong> <span id="confirmBookTitle"></span></p>
            <p><strong>Accession #:</strong> <span id="confirmAccessionNumber"></span></p>
            <p><strong>Condition:</strong> <span id="confirmCondition"></span></p>
          </div>
          <div class="form-group"><label for="borrowDueDate">Due Date:</label><input type="date" id="borrowDueDate" class="form-control" required></div>
          <div class="form-actions">
            <button class="btn-secondary" onclick="backToCopySelection()">&#8592; Back</button>
            <button class="btn-primary" onclick="confirmBorrowing()">Confirm Borrow</button>
          </div>
        </div>
      </div>
    </div>

    <div id="bulkBorrowModal" class="modal" style="display:none;">
      <div class="modal-content" style="max-width:1000px;max-height:90vh;overflow-y:auto;">
        <span class="close" onclick="closeBulkBorrowModal()">&times;</span>
        <h2>&#128218; Borrow Books</h2>
        <div class="borrow-student-info">
          <p><strong>Student:</strong> <span id="bulkBorrowStudentName"></span></p>
          <p><strong>Student ID:</strong> <span id="bulkBorrowStudentId"></span></p>
        </div>
        <div id="bulkBorrowInstructions"></div>
        <div class="bulk-borrow-container">
          <div class="selected-books-cart">
            <h3>&#128214; Cart (<span id="selectedBooksCount">0</span>)</h3>
            <div id="selectedBooksCart" class="cart-items"><p class="empty-cart">Click books below to add them here</p></div>
            <div class="form-group" style="margin-top:20px;"><label for="bulkBorrowDueDate">&#128197; Return Date:</label><input type="date" id="bulkBorrowDueDate" class="form-control" required></div>
            <button class="btn-primary" onclick="confirmBulkBorrowing()" style="width:100%;margin-top:15px;font-size:16px;padding:12px;"><span class="material-symbols-outlined">check_circle</span>Confirm Borrow (<span id="confirmBooksCount">0</span> books)</button>
          </div>
          <div class="available-books-section">
            <h3>&#128218; Available Books</h3>
            <input type="text" id="bulkBookSearch" class="form-control" placeholder="&#128269; Search by title or author..." style="margin-bottom:15px;">
            <div id="bulkBooksList" class="books-list" style="max-height:500px;overflow-y:auto;"><p class="loading-text">Loading books...</p></div>
          </div>
        </div>
      </div>
    </div>
  `
}) %>

