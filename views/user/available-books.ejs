<%- include('../partials/user-sidebar-top', {
  pageTitle: 'Available Books - SPIST Library',
  activePage: 'available-books',
  extraHead: '<link rel="stylesheet" href="/css/student/quick-borrow.css">'
}) %>

<script>
  // ==================================================
  // Available Books Page — shows only available books
  // with single-book Quick Borrow via the shared modal
  // ==================================================

  let _availBooks = [];
  let _availFiltered = [];
  let _availSearchTimer = null;
  let _availFilters = { search: '', category: '' };

  // Auth guard
  document.addEventListener('DOMContentLoaded', async function () {
    const isLoggedIn = sessionStorage.getItem('isLoggedIn');
    const userRole   = sessionStorage.getItem('userRole');
    const studentId  = sessionStorage.getItem('studentId');

    if (!isLoggedIn || userRole !== 'student' || !studentId) {
      alert('Please log in with student credentials to access this page.');
      sessionStorage.clear();
      window.location.href = '/login';
      return;
    }

    const userNameEl = document.getElementById('userName');
    const userIDEl   = document.getElementById('userID');
    if (userNameEl) userNameEl.textContent = sessionStorage.getItem('userName') || 'Student';
    if (userIDEl)   userIDEl.textContent   = sessionStorage.getItem('userID')   || 'STD-0000-000';

    await loadAvailableBooks();
    _setupListeners();
  });

  async function loadAvailableBooks() {
    try {
      const resp = await fetchWithCsrf('/api/books');
      if (!resp.ok) throw new Error('Failed to fetch books: ' + resp.status);
      const result = await resp.json();
      // Keep only books with available copies
      _availBooks = (result.data || []).filter(b => (b.available_quantity || 0) > 0);
      _availFiltered = _availBooks;
      _populateCategories();
      _renderTable(_availBooks);
    } catch (err) {
      console.error('[AvailBooks]', err);
      document.querySelector('#availBooksBody').innerHTML =
        `<tr><td colspan="7" class="text-center" style="color:red;padding:20px;">Error loading books: ${err.message}</td></tr>`;
    }
  }

  function _populateCategories() {
    const sel = document.getElementById('availCategoryFilter');
    if (!sel) return;
    const cats = [...new Set(_availBooks.map(b => b.category).filter(Boolean))].sort();
    sel.innerHTML = '<option value="">All Categories</option>';
    cats.forEach(c => {
      const o = document.createElement('option');
      o.value = c; o.textContent = c;
      sel.appendChild(o);
    });
  }

  function _applyFilters() {
    _availFiltered = _availBooks.filter(b => {
      if (_availFilters.search) {
        const q = _availFilters.search.toLowerCase();
        if (!(
          (b.title  && b.title.toLowerCase().includes(q)) ||
          (b.author && b.author.toLowerCase().includes(q)) ||
          (b.isbn   && b.isbn.toLowerCase().includes(q))
        )) return false;
      }
      if (_availFilters.category && b.category !== _availFilters.category) return false;
      return true;
    });
    _renderTable(_availFiltered);
  }

  function _renderTable(books) {
    const tbody = document.getElementById('availBooksBody');
    if (!tbody) return;
    if (!books.length) {
      tbody.innerHTML = `<tr><td colspan="7" class="text-center" style="padding:32px;color:#666;">
        <i class="bi bi-search" style="font-size:2.5rem;color:#ccc;display:block;margin-bottom:10px;"></i>
        No available books found
      </td></tr>`;
      return;
    }
    tbody.innerHTML = books.map(b => `
      <tr>
        <td>${b.id || '—'}</td>
        <td><strong>${b.title || '—'}</strong></td>
        <td>${b.author || 'Unknown'}</td>
        <td>${b.category || 'Uncategorized'}</td>
        <td>${b.isbn || '—'}</td>
        <td style="text-align:center;">
          <span class="u-badge u-badge-available">${b.available_quantity} / ${b.quantity || '?'}</span>
        </td>
        <td>
          <button class="u-btn u-btn-primary" onclick="_borrowBook('${b.id}')">
            <i class="bi bi-book-fill"></i> Borrow
          </button>
        </td>
      </tr>
    `).join('');
  }

  function _setupListeners() {
    const searchInput = document.getElementById('availSearchInput');
    if (searchInput) {
      searchInput.addEventListener('input', e => {
        clearTimeout(_availSearchTimer);
        _availSearchTimer = setTimeout(() => {
          _availFilters.search = e.target.value.trim();
          _applyFilters();
        }, 300);
      });
    }
    const catFilter = document.getElementById('availCategoryFilter');
    if (catFilter) {
      catFilter.addEventListener('change', e => {
        _availFilters.category = e.target.value;
        _applyFilters();
      });
    }
    const clearBtn = document.getElementById('availClearBtn');
    if (clearBtn) {
      clearBtn.addEventListener('click', () => {
        _availFilters = { search: '', category: '' };
        if (searchInput) searchInput.value = '';
        if (catFilter)   catFilter.value   = '';
        _applyFilters();
      });
    }
  }

  // Open Quick Borrow modal for a single book
  async function _borrowBook(bookId) {
    // We reuse the Quick Borrow modal pattern from browse-books
    // but load it inline — simpler single-book flow uses the shared modal below
    const modal  = document.getElementById('avail-borrow-modal');
    const msgBox = document.getElementById('avail-borrow-msg');
    const btn    = document.getElementById('avail-confirm-btn');
    const dateIn = document.getElementById('avail-return-date');
    if (!modal) return;

    // Store selected book
    modal.dataset.bookId = bookId;

    // Set date limits
    const today = new Date();
    const min = new Date(today); min.setDate(today.getDate() + 1);
    const max = new Date(today); max.setDate(today.getDate() + 7);
    dateIn.min = min.toISOString().split('T')[0];
    dateIn.max = max.toISOString().split('T')[0];
    dateIn.value = max.toISOString().split('T')[0];

    msgBox.innerHTML = '';
    btn.disabled = false;
    btn.textContent = 'Confirm Borrow';

    modal.style.display = 'flex';
  }

  async function _confirmBorrow() {
    const modal  = document.getElementById('avail-borrow-modal');
    const msgBox = document.getElementById('avail-borrow-msg');
    const btn    = document.getElementById('avail-confirm-btn');
    const dateIn = document.getElementById('avail-return-date');

    const bookId    = modal.dataset.bookId;
    const returnDate = dateIn.value;
    const studentId  = sessionStorage.getItem('studentId');

    if (!returnDate) {
      msgBox.innerHTML = '<p style="color:#c62828;">Please select a return date.</p>';
      return;
    }
    if (!studentId) {
      msgBox.innerHTML = '<p style="color:#c62828;">Session expired. Please log in again.</p>';
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Processing…';
    msgBox.innerHTML = '<p style="color:#1565c0;font-style:italic;">Processing your request…</p>';

    try {
      const resp = await fetchWithCsrf('/api/students/borrow-book', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ bookId, studentId, returnDate })
      });
      const result = await resp.json();
      if (!resp.ok) throw new Error(result.error || result.message || 'Failed to borrow book');

      msgBox.innerHTML = `<p style="color:#2e7d32;font-weight:600;">Book borrowed successfully! Due: ${new Date(returnDate).toLocaleDateString()}</p>`;
      setTimeout(async () => {
        modal.style.display = 'none';
        await loadAvailableBooks();
      }, 1800);
    } catch (err) {
      console.error('[Borrow]', err);
      msgBox.innerHTML = `<p style="color:#c62828;font-weight:600;">Error: ${err.message}</p>`;
      btn.disabled = false;
      btn.textContent = 'Confirm Borrow';
    }
  }

  function _cancelBorrow() {
    document.getElementById('avail-borrow-modal').style.display = 'none';
  }
</script>

<!-- ═══ Section Header ═══ -->
<div class="u-section-header">
  <h2>Available Books</h2>
  <p>Books currently available to borrow from our library</p>
</div>

<!-- ═══ Main Card ═══ -->
<div class="u-section-card">

  <!-- Filter Bar -->
  <div class="u-filter-bar">
    <div class="u-search-wrap">
      <i class="fas fa-search u-search-icon"></i>
      <input
        id="availSearchInput"
        type="text"
        class="u-search-input"
        placeholder="Search by title, author or ISBN…"
      />
    </div>
    <div class="u-filter-group">
      <select id="availCategoryFilter" class="u-filter-select">
        <option value="">All Categories</option>
      </select>
      <button id="availClearBtn" class="u-clear-btn">
        <i class="fas fa-filter"></i> Clear
      </button>
    </div>
  </div>

  <!-- Table -->
  <div class="u-table-wrapper">
    <table class="user-table">
      <thead>
        <tr>
          <th style="width:60px;">ID</th>
          <th>Title</th>
          <th>Author</th>
          <th>Category</th>
          <th>ISBN</th>
          <th style="width:110px;text-align:center;">Available</th>
          <th style="width:110px;">Action</th>
        </tr>
      </thead>
      <tbody id="availBooksBody">
        <tr><td colspan="7" class="text-center">Loading…</td></tr>
      </tbody>
    </table>
  </div>

</div><!-- /.u-section-card -->

<!-- ═══ Single-Book Borrow Modal ═══ -->
<div id="avail-borrow-modal" class="u-modal-overlay" style="display:none;" data-book-id="">
  <div class="u-modal-box">
    <h2>Confirm Borrow</h2>
    <p>Select a return date (max 7 days from today).</p>
    <div class="u-form-group">
      <label for="avail-return-date">Return Date</label>
      <input type="date" id="avail-return-date" class="u-date-input" required />
    </div>
    <div id="avail-borrow-msg"></div>
    <div class="u-modal-actions">
      <button id="avail-confirm-btn" class="u-btn-confirm" onclick="_confirmBorrow()">Confirm Borrow</button>
      <button class="u-btn-cancel" onclick="_cancelBorrow()">Cancel</button>
    </div>
  </div>
</div>

<%- include('../partials/user-sidebar-bottom') %>
