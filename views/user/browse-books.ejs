<%- include('../partials/user-sidebar-top', {
  pageTitle: 'Browse Books - SPIST Library',
  activePage: 'browse-books',
  extraHead: '<link rel="stylesheet" href="/css/student/quick-borrow.css"><script src="/js/student/browse-books.js"><\/script>'
}) %>

<!-- ═══ Section Header ═══ -->
<div class="u-section-header">
  <h2>Browse Library Books</h2>
  <p>Search and filter from our collection of books</p>
</div>

<!-- ═══ Main Card ═══ -->
<div class="u-section-card">

  <!-- Filter Bar -->
  <div class="u-filter-bar">
    <input type="checkbox" id="select-all-checkbox" class="u-filter-check" title="Select all" />
    <div class="u-search-wrap">
      <i class="fas fa-search u-search-icon"></i>
      <input
        id="searchInput"
        type="text"
        class="u-search-input"
        placeholder="Search by title, author, accession no. or category..."
      />
    </div>
    <div class="u-filter-group">
      <select id="categoryFilter" class="u-filter-select">
        <option value="">All Categories</option>
      </select>
      <select id="statusFilter" class="u-filter-select">
        <option value="">All Status</option>
        <option value="available">Available</option>
        <option value="borrowed">Borrowed</option>
      </select>
      <button id="clearFiltersBtn" class="u-clear-btn">
        <i class="fas fa-filter"></i> Clear
      </button>
    </div>
  </div>

  <!-- Selection Toolbar -->
  <div class="selection-toolbar" style="display: none;">
    <div style="display: flex; align-items: center; gap: 16px;">
      <span style="font-size: 15px; font-weight: 700;">
        <i class="fas fa-check-square"></i>
        <span id="selected-count">0</span> selected (max 5)
      </span>
    </div>
    <div style="display: flex; align-items: center; gap: 10px;">
      <button
        id="borrow-selected-btn"
        disabled
        title="Open Smart Borrow modal with selected books"
        class="action-btn btn-borrow"
        style="padding: 8px 16px;"
      >
        <i class="fas fa-book-reader"></i> Borrow Selected
      </button>
      <button
        id="clear-selection-btn"
        title="Clear all selections"
        style="display: none; padding: 8px 14px;"
      >
        <i class="fas fa-times"></i> Clear
      </button>
    </div>
    <div id="selection-message" style="display: none; font-size: 13px; gap: 6px; align-items: center;">
      <i class="fas fa-exclamation-circle"></i>
      <span>Maximum 5 books can be selected</span>
    </div>
  </div>

  <!-- Books Table -->
  <div class="u-table-wrapper">
    <table class="user-table">
      <thead>
        <tr>
          <th style="width: 40px; text-align: center;">
            <input type="checkbox" id="select-all-checkbox" aria-label="Select all books"
                   style="cursor: pointer; width: 18px; height: 18px;">
          </th>
          <th style="width: 60px;">ID</th>
          <th>Title</th>
          <th>Author</th>
          <th style="width: 100px; text-align: center;">Quantity</th>
          <th>Category</th>
          <th>ISBN</th>
          <th style="width: 150px;">Status</th>
          <th style="width: 120px;">Action</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td colspan="9" class="text-center">Loading books...</td>
        </tr>
      </tbody>
    </table>
  </div>

</div><!-- /.u-section-card -->

<!-- ═══ Smart Borrow Modal (Quick Borrow) ═══ -->
<div id="modal-user" class="qb-modal qb-hidden" aria-hidden="true">
  <div class="qb-backdrop" onclick="closeModal(event)"></div>
  <div class="qb-card" role="dialog" aria-modal="true" aria-labelledby="qbTitle" onclick="event.stopPropagation()">
    <div class="qb-header">
      <h2 id="qbTitle">Quick Borrow</h2>
    </div>
    <div class="qb-body">
      <!-- Book Cart -->
      <div class="qb-section">
        <div class="qb-section-head">
          <h3>Book Cart</h3>
          <button class="qb-icon-btn" type="button" id="qbDueBtn" title="Set due date"
                  onclick="document.getElementById('returnDate').showPicker?.(); document.getElementById('returnDate').focus();">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M7 2v2M17 2v2M3 9h18M5 6h14a2 2 0 0 1 2 2v13a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2Z"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
          </button>
          <input id="returnDate" class="qb-date" type="date" onchange="updateConfirmButtonState()" required />
        </div>
        <div id="bookDetailsContainer" class="qb-cart">
          <div style="color: #999; font-style: italic; text-align: center; padding: 20px;">
            No book selected yet. Search below to add books.
          </div>
        </div>
      </div>

      <!-- Available Books -->
      <div class="qb-section">
        <h3>Available Books</h3>
        <div class="qb-search">
          <span class="qb-search-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M21 21l-4.3-4.3M10.5 18a7.5 7.5 0 1 1 0-15 7.5 7.5 0 0 1 0 15Z"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
          </span>
          <input id="smartSearchInput" type="text" placeholder="Search" oninput="handleSmartSearch(this.value)" autocomplete="off" />
        </div>
        <div id="availableBooksContainer" class="qb-list" role="list">
          <div style="color: #999; font-style: italic; text-align: center; padding: 15px;">
            Type to search for books...
          </div>
        </div>
      </div>

      <div class="qb-footer">
        <button id="confirmBorrowBtn" class="qb-done" type="button" onclick="handleBorrow()" disabled>Done</button>
        <button class="qb-cancel" type="button" onclick="closeModal(event)">Cancel</button>
      </div>
    </div>
    <div id="borrowMessageContainer" class="message-container"></div>
  </div>
</div>

<%- include('../partials/user-sidebar-bottom') %>
